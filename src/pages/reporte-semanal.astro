---
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Reporte Semanal — Demo Klimze</title>
  <link rel="stylesheet" href="/demo.css" />
</head>
<body>

<!-- NAV -->
<nav class="demo-nav">
  <a href="/demos" class="back-link">
    <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
    Demos
  </a>
  <div class="nav-demo-name">📊 Reporte Semanal</div>
  <div class="nav-price">$1,000</div>
</nav>

<!-- HEADER -->
<header class="demo-header">
  <canvas id="mini-canvas"></canvas>
  <div class="demo-header-content">
    <div class="demo-header-icon">📊</div>
    <h1>Reporte <span>Semanal</span></h1>
    <p>Ingresa el cliente y sus métricas. El sistema recopila datos de todas las fuentes, genera el reporte ejecutivo con IA y lo envía automáticamente.</p>
    <div style="display:flex;flex-direction:column;gap:10px;width:100%;max-width:380px;margin-top:8px">
      <div class="form-row" style="margin:0"><label>Cliente / Negocio</label><input id="inp-client" placeholder="Ej: Farmacia San José" /></div>
      <div class="form-row" style="margin:0">
        <label>Métricas de la semana</label>
        <textarea id="inp-metrics" placeholder="Ej: 142 mensajes WhatsApp, 38 citas, 12 cancelaciones, ventas $4,200, 6 reseñas nuevas, 850 impresiones en Meta Ads..."></textarea>
      </div>
      <button class="btn-start-main" id="start-btn" onclick="initDemo()" style="margin-top:4px">▶ Generar reporte</button>
    </div>
  </div>
</header>

<!-- DEMO AREA -->
<div class="demo-container">
  <div id="demo-area" style="display:none">
    <div class="steps-bar">
      <div class="step-item current" id="step-1">1. Recopilando</div>
      <div class="step-item" id="step-2">2. Redactando</div>
      <div class="step-item" id="step-3">3. Reporte listo</div>
    </div>

    <!-- Phase 1: Data streams -->
    <div class="phase active" id="phase-1">
      <div class="tag-label">Recopilando datos de todas las fuentes</div>
      <div class="data-streams" id="streams"></div>
    </div>

    <!-- Phase 2: AI writing -->
    <div class="phase" id="phase-2">
      <div class="analysis-wrap">
        <div class="analysis-ring"></div>
        <div class="analysis-label">Redactando reporte ejecutivo con IA...</div>
      </div>
    </div>

    <!-- Phase 3: Report output -->
    <div class="phase" id="phase-3">
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:12px;flex-wrap:gap:8px">
        <div class="tag-label" style="margin:0">📨 Reporte enviado al cliente</div>
        <div style="font-size:11px;color:rgba(255,255,255,.3)" id="report-meta"></div>
      </div>
      <div class="report-output" id="rep-output"></div>
      <button class="reset-btn" onclick="resetDemo()">↺ Reiniciar simulación</button>
    </div>
  </div>
</div>

<script>
(function(){
  const c=document.getElementById('mini-canvas'),ctx=c.getContext('2d');
  let W,H,nodes=[];const N=40,DIST=140,SPD=0.35;
  function resize(){W=c.width=c.offsetWidth;H=c.height=c.offsetHeight}
  function init(){nodes=[];for(let i=0;i<N;i++)nodes.push({x:Math.random()*W,y:Math.random()*H,vx:(Math.random()-.5)*SPD,vy:(Math.random()-.5)*SPD,r:Math.random()*1.5+1,o:Math.random()*.4+.3})}
  function draw(){ctx.clearRect(0,0,W,H);for(let i=0;i<nodes.length;i++)for(let j=i+1;j<nodes.length;j++){const dx=nodes[j].x-nodes[i].x,dy=nodes[j].y-nodes[i].y,d=Math.sqrt(dx*dx+dy*dy);if(d<DIST){const a=(1-d/DIST)*.28;ctx.beginPath();ctx.moveTo(nodes[i].x,nodes[i].y);ctx.lineTo(nodes[j].x,nodes[j].y);ctx.strokeStyle=`rgba(99,102,241,${a})`;ctx.lineWidth=.7;ctx.stroke()}}nodes.forEach(n=>{ctx.beginPath();ctx.arc(n.x,n.y,n.r,0,Math.PI*2);ctx.fillStyle=`rgba(180,190,255,${n.o})`;ctx.fill()})}
  function update(){nodes.forEach(n=>{n.x+=n.vx;n.y+=n.vy;if(n.x<0||n.x>W)n.vx*=-1;if(n.y<0||n.y>H)n.vy*=-1})}
  function loop(){update();draw();requestAnimationFrame(loop)}
  new ResizeObserver(()=>{resize();init()}).observe(c.parentElement);
  resize();init();loop();
})();

async function groq(prompt,temp=0.7){
  const r=await fetch('/api/groq',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({model:'llama-3.3-70b-versatile',messages:[{role:'user',content:prompt}],temperature:temp})});
  const d=await r.json();return d.choices[0].message.content;
}
function sleep(ms){return new Promise(r=>setTimeout(r,ms))}
function typewriter(el,text,speed=9){
  return new Promise(res=>{let i=0;el.textContent='';const t=setInterval(()=>{el.textContent+=text[i++];el.scrollTop=el.scrollHeight;if(i>=text.length){clearInterval(t);res()}},speed)});
}
function setPhase(n){
  document.querySelectorAll('.phase').forEach((p,i)=>p.classList.toggle('active',i===n-1));
  document.querySelectorAll('.step-item').forEach((s,i)=>{s.className='step-item'+(i<n-1?' done':i===n-1?' current':'')});
}

const SOURCES=[
  {icon:'💬',name:'WhatsApp Business'},
  {icon:'📅',name:'Citas agendadas'},
  {icon:'⭐',name:'Google Reviews'},
  {icon:'💰',name:'Ventas / Facturación'},
  {icon:'📊',name:'Meta Ads'},
];
let state={client:'',metrics:''};

async function initDemo(){
  state.client=document.getElementById('inp-client').value||'Cliente';
  state.metrics=document.getElementById('inp-metrics').value||'142 mensajes, 38 citas, 6 reseñas, $4200 ventas';
  document.getElementById('start-btn').style.display='none';
  document.getElementById('demo-area').style.display='block';
  document.getElementById('demo-area').scrollIntoView({behavior:'smooth',block:'start'});
  setPhase(1);
  buildStreams();
  await animateStreams();
  await sleep(500);
  setPhase(2);
  const prompt=`Genera un reporte semanal ejecutivo profesional para "${state.client}". Estructura:\n\n📋 RESUMEN EJECUTIVO\n(2-3 líneas)\n\n✅ HIGHLIGHTS DE LA SEMANA\n(3 puntos con ícono bullet)\n\n⚠️ ÁREAS DE MEJORA\n(2 puntos)\n\n📌 ACCIÓN RECOMENDADA\n(1 acción concreta para la próxima semana)\n\nTono: profesional, directo, orientado a resultados. Español.\nDatos: ${state.metrics}`;
  const text=await groq(prompt,.45);
  state.text=text;
  await sleep(400);
  const now=new Date();
  document.getElementById('report-meta').textContent=`Generado: ${now.toLocaleDateString('es')} ${now.toLocaleTimeString('es',{hour:'2-digit',minute:'2-digit'})}`;
  setPhase(3);
  await typewriter(document.getElementById('rep-output'),text,8);
}

function buildStreams(){
  const el=document.getElementById('streams');el.innerHTML='';
  const nums=state.metrics.match(/\d+[\.,]?\d*/g)||[];
  SOURCES.forEach((s,i)=>{
    const v=nums[i]||Math.floor(Math.random()*200+30);
    const it=document.createElement('div');it.className='stream-item';it.id=`si-${i}`;
    it.innerHTML=`<div class="stream-icon">${s.icon}</div><div class="stream-name">${s.name}</div><div class="stream-bar-wrap"><div class="stream-bar" id="sb-${i}"></div></div><div class="stream-val" id="sv-${i}">—</div>`;
    el.appendChild(it);
  });
}

async function animateStreams(){
  for(let i=0;i<SOURCES.length;i++){
    await sleep(300);
    const bar=document.getElementById(`sb-${i}`);
    const val=document.getElementById(`sv-${i}`);
    const nums=state.metrics.match(/\d+[\.,]?\d*/g)||[];
    const v=nums[i]||Math.floor(Math.random()*200+30);
    if(bar)bar.style.width=Math.min(100,25+i*12+Math.random()*25)+'%';
    if(val)val.textContent=v;
  }
  await sleep(900);
}

function resetDemo(){
  state={client:'',metrics:''};
  document.getElementById('start-btn').style.display='';
  document.getElementById('demo-area').style.display='none';
  document.getElementById('rep-output').textContent='';
  document.getElementById('streams').innerHTML='';
  window.scrollTo({top:0,behavior:'smooth'});
}
</script>
</body>
</html>
