---
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Demos en Vivo — Klimze</title>
  <style>
    *{box-sizing:border-box;margin:0;padding:0}
    body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;background:#06060e;color:#fff;overflow-x:hidden}

    /* ── HERO ── */
    .hero{position:relative;width:100%;height:100vh;display:flex;align-items:center;justify-content:center;overflow:hidden}
    #network-canvas{position:absolute;inset:0;width:100%;height:100%}
    .hero-content{position:relative;z-index:10;text-align:center;display:flex;flex-direction:column;align-items:center;gap:24px}
    .hero-badge{display:inline-flex;align-items:center;gap:7px;background:rgba(99,102,241,.12);border:1px solid rgba(99,102,241,.3);color:#a5b4fc;font-size:12px;font-weight:600;padding:5px 14px;border-radius:20px;letter-spacing:.5px}
    .dot-pulse{width:6px;height:6px;background:#7c7cff;border-radius:50%;animation:pulse 1.5s infinite}
    @keyframes pulse{0%,100%{opacity:1;transform:scale(1)}50%{opacity:.4;transform:scale(.8)}}
    .hero h1{font-size:clamp(28px,5vw,56px);font-weight:800;line-height:1.15;letter-spacing:-.02em;max-width:640px}
    .hero h1 span{background:linear-gradient(135deg,#818cf8,#60a5fa);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
    .hero p{color:rgba(255,255,255,.45);font-size:16px;max-width:380px;line-height:1.6}
    .btn-hero{display:inline-flex;align-items:center;gap:10px;background:#6366f1;color:#fff;border:none;border-radius:14px;padding:16px 36px;font-size:16px;font-weight:700;cursor:pointer;transition:all .2s;text-decoration:none;box-shadow:0 0 40px rgba(99,102,241,.4),0 8px 32px rgba(0,0,0,.4)}
    .btn-hero:hover{background:#5558e8;transform:translateY(-2px);box-shadow:0 0 60px rgba(99,102,241,.55),0 12px 40px rgba(0,0,0,.5)}
    .scroll-hint{color:rgba(255,255,255,.2);font-size:11px;letter-spacing:2px;text-transform:uppercase}

    /* ── LIBRARY ── */
    .library{padding:72px 20px 100px;max-width:1160px;margin:0 auto}
    .library-hdr{text-align:center;margin-bottom:52px}
    .library-hdr h2{font-size:clamp(20px,3.5vw,34px);font-weight:800;margin-bottom:8px}
    .library-hdr p{color:rgba(255,255,255,.35);font-size:14px}

    /* ── DEMO CARD ── */
    .demos-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(340px,1fr));gap:22px}
    .demo-card{background:#0d0d1a;border:1px solid rgba(99,102,241,.15);border-radius:20px;overflow:hidden;transition:border-color .25s}
    .demo-card.active{border-color:rgba(99,102,241,.5);grid-column:1/-1}
    .card-hdr{padding:20px 22px 16px;border-bottom:1px solid rgba(255,255,255,.05);display:flex;align-items:flex-start;gap:14px}
    .card-icon{font-size:26px;flex-shrink:0;margin-top:2px}
    .card-meta{flex:1}
    .card-title{font-weight:700;font-size:15px;margin-bottom:3px}
    .card-desc{color:rgba(255,255,255,.38);font-size:13px;line-height:1.5}
    .card-price{font-size:11px;font-weight:700;color:#818cf8;background:rgba(99,102,241,.1);border:1px solid rgba(99,102,241,.2);padding:2px 9px;border-radius:20px;white-space:nowrap;align-self:flex-start}

    /* ── IDLE ── */
    .demo-idle{padding:20px 22px 22px}
    .demo-idle-desc{color:rgba(255,255,255,.4);font-size:13px;line-height:1.6;margin-bottom:16px}
    .btn-start{display:inline-flex;align-items:center;gap:8px;background:#6366f1;color:#fff;border:none;border-radius:10px;padding:11px 22px;font-size:14px;font-weight:600;cursor:pointer;transition:background .2s}
    .btn-start:hover{background:#5558e8}

    /* ── ACTIVE ── */
    .demo-active{display:none;padding:0 0 4px}
    .demo-card.active .demo-active{display:block}
    .demo-card.active .demo-idle{display:none}

    /* Steps bar */
    .steps-bar{display:flex;gap:0;padding:14px 22px 0}
    .step-item{flex:1;text-align:center;padding:8px 4px;font-size:12px;font-weight:600;color:rgba(255,255,255,.25);border-bottom:2px solid rgba(255,255,255,.06);cursor:default;transition:all .25s}
    .step-item.done{color:rgba(99,102,241,.6);border-bottom-color:rgba(99,102,241,.3)}
    .step-item.current{color:#818cf8;border-bottom-color:#6366f1}

    /* Phase containers */
    .phase{display:none;padding:18px 22px 20px}
    .phase.active{display:block}

    /* ── CHAT UI ── */
    .chat-window{background:#080812;border:1px solid rgba(255,255,255,.06);border-radius:14px;overflow:hidden;display:flex;flex-direction:column;height:360px}
    .chat-header{background:#0f0f1e;padding:12px 16px;display:flex;align-items:center;gap:10px;border-bottom:1px solid rgba(255,255,255,.06)}
    .chat-avatar{width:34px;height:34px;background:linear-gradient(135deg,#6366f1,#818cf8);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:16px}
    .chat-bot-name{font-weight:600;font-size:13px}
    .chat-bot-status{font-size:11px;color:#4ade80;display:flex;align-items:center;gap:4px}
    .online-dot{width:6px;height:6px;background:#4ade80;border-radius:50%}
    .chat-messages{flex:1;overflow-y:auto;padding:14px;display:flex;flex-direction:column;gap:10px;scroll-behavior:smooth}
    .chat-messages::-webkit-scrollbar{width:3px}
    .chat-messages::-webkit-scrollbar-thumb{background:rgba(99,102,241,.3);border-radius:3px}
    .msg{max-width:80%;padding:9px 13px;border-radius:14px;font-size:13px;line-height:1.55;animation:msgIn .2s ease}
    @keyframes msgIn{from{opacity:0;transform:translateY(4px)}to{opacity:1;transform:none}}
    .msg.bot{background:#1a1a2e;color:rgba(255,255,255,.85);border-bottom-left-radius:4px;align-self:flex-start}
    .msg.user{background:#6366f1;color:#fff;border-bottom-right-radius:4px;align-self:flex-end}
    .typing{display:flex;align-items:center;gap:5px;padding:8px 13px;background:#1a1a2e;border-radius:14px;border-bottom-left-radius:4px;align-self:flex-start;animation:msgIn .2s ease}
    .typing span{width:7px;height:7px;background:rgba(255,255,255,.4);border-radius:50%;animation:bounce .8s infinite}
    .typing span:nth-child(2){animation-delay:.15s}
    .typing span:nth-child(3){animation-delay:.3s}
    @keyframes bounce{0%,60%,100%{transform:translateY(0)}30%{transform:translateY(-5px)}}
    .chat-input-row{display:flex;gap:8px;padding:10px 12px;border-top:1px solid rgba(255,255,255,.06);background:#0a0a16}
    .chat-input{flex:1;background:#1a1a2e;border:1px solid rgba(255,255,255,.08);border-radius:22px;padding:9px 14px;color:#fff;font-size:13px;outline:none;transition:border-color .2s}
    .chat-input:focus{border-color:rgba(99,102,241,.5)}
    .chat-input::placeholder{color:rgba(255,255,255,.25)}
    .chat-send{background:#6366f1;border:none;border-radius:50%;width:36px;height:36px;display:flex;align-items:center;justify-content:center;cursor:pointer;transition:background .2s;flex-shrink:0}
    .chat-send:hover{background:#5558e8}
    .chat-send:disabled{background:#333;cursor:not-allowed}

    /* ── ANALYSIS LOADING ── */
    .analysis-wrap{display:flex;flex-direction:column;align-items:center;justify-content:center;gap:18px;padding:32px 0;min-height:220px}
    .analysis-ring{width:64px;height:64px;border:3px solid rgba(99,102,241,.2);border-top-color:#6366f1;border-radius:50%;animation:spin 1s linear infinite}
    @keyframes spin{to{transform:rotate(360deg)}}
    .analysis-label{color:rgba(255,255,255,.55);font-size:14px;text-align:center}
    .analysis-steps{display:flex;flex-direction:column;gap:8px;width:100%;max-width:280px}
    .astep{display:flex;align-items:center;gap:10px;font-size:12px;color:rgba(255,255,255,.4);transition:color .3s}
    .astep.done{color:#4ade80}
    .astep.active{color:#818cf8}
    .astep-dot{width:8px;height:8px;border-radius:50%;background:currentColor;flex-shrink:0}

    /* ── NOTIFICATION CARD ── */
    .notif-wrap{display:flex;flex-direction:column;gap:14px}
    .notif-label{font-size:11px;font-weight:700;color:rgba(255,255,255,.3);text-transform:uppercase;letter-spacing:1px}
    .notif-phone{background:#0a0a14;border:1px solid rgba(255,255,255,.07);border-radius:14px;overflow:hidden}
    .notif-phone-bar{background:#111;padding:8px 14px;display:flex;align-items:center;gap:8px;border-bottom:1px solid rgba(255,255,255,.05)}
    .notif-app-icon{width:28px;height:28px;background:linear-gradient(135deg,#25d366,#128c7e);border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:14px}
    .notif-app-name{font-size:12px;font-weight:600;color:rgba(255,255,255,.7)}
    .notif-time{font-size:11px;color:rgba(255,255,255,.25);margin-left:auto}
    .notif-body{padding:14px 16px}
    .notif-title{font-size:13px;font-weight:700;margin-bottom:8px;color:#4ade80}
    .notif-line{font-size:12px;color:rgba(255,255,255,.65);margin-bottom:5px;display:flex;gap:6px}
    .notif-line strong{color:rgba(255,255,255,.85)}
    .notif-divider{height:1px;background:rgba(255,255,255,.05);margin:10px 0}
    .notif-suggestion{background:rgba(99,102,241,.08);border:1px solid rgba(99,102,241,.18);border-radius:10px;padding:10px 12px;font-size:12px;color:rgba(255,255,255,.7);line-height:1.55;margin-top:4px}
    .notif-suggestion-label{font-size:10px;font-weight:700;color:#818cf8;text-transform:uppercase;letter-spacing:.5px;margin-bottom:5px}
    .reset-btn{width:100%;background:rgba(99,102,241,.12);border:1px solid rgba(99,102,241,.25);color:#818cf8;border-radius:10px;padding:11px;font-size:13px;font-weight:600;cursor:pointer;transition:all .2s;margin-top:6px}
    .reset-btn:hover{background:rgba(99,102,241,.2)}

    /* ── PIPELINE BOARD ── */
    .pipeline-board{display:flex;gap:8px;overflow-x:auto;padding-bottom:8px}
    .pipeline-board::-webkit-scrollbar{height:3px}
    .pipeline-board::-webkit-scrollbar-thumb{background:rgba(99,102,241,.3);border-radius:3px}
    .pipe-col{flex:0 0 160px;background:#0a0a14;border:1px solid rgba(255,255,255,.06);border-radius:12px;padding:10px 10px 12px}
    .pipe-col-title{font-size:11px;font-weight:700;color:rgba(255,255,255,.3);text-transform:uppercase;letter-spacing:1px;margin-bottom:10px}
    .pipe-card{background:#1a1a2e;border-radius:10px;padding:10px 11px;font-size:12px;color:rgba(255,255,255,.7);line-height:1.5;border:1px solid rgba(99,102,241,.12);transition:all .4s}
    .pipe-card.highlight{border-color:#6366f1;background:rgba(99,102,241,.15);color:#fff;box-shadow:0 0 20px rgba(99,102,241,.25)}
    .pipe-card-name{font-weight:700;color:#fff;margin-bottom:3px}
    .pipe-msg-preview{margin-top:10px;background:rgba(255,255,255,.04);border-radius:8px;padding:8px 10px;font-size:11px;color:rgba(255,255,255,.5);line-height:1.5;border-left:2px solid rgba(99,102,241,.4)}
    .pipe-msg-preview.show{display:block}
    .pipe-msg-label{font-size:10px;font-weight:600;color:#818cf8;margin-bottom:4px;text-transform:uppercase;letter-spacing:.5px}

    /* ── CONTENT DEMO ── */
    .content-output{background:#0a0a14;border:1px solid rgba(255,255,255,.06);border-radius:14px;padding:16px;min-height:160px;font-size:13px;line-height:1.7;color:rgba(255,255,255,.75);white-space:pre-wrap}
    .calendar-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:8px;margin-top:14px}
    .cal-item{background:#0a0a14;border:1px solid rgba(99,102,241,.15);border-radius:10px;padding:10px;font-size:11px}
    .cal-day{font-weight:700;color:#818cf8;margin-bottom:4px}
    .cal-text{color:rgba(255,255,255,.5);line-height:1.4}
    .cal-badge{display:inline-block;background:rgba(74,222,128,.1);color:#4ade80;border-radius:20px;padding:2px 8px;font-size:10px;font-weight:600;margin-top:5px}

    /* ── REPORT DEMO ── */
    .data-streams{display:flex;flex-direction:column;gap:8px;margin-bottom:16px}
    .stream-item{display:flex;align-items:center;gap:10px;background:#0a0a14;border-radius:10px;padding:10px 14px;border:1px solid rgba(255,255,255,.06)}
    .stream-icon{font-size:18px;flex-shrink:0}
    .stream-name{font-size:13px;font-weight:600;flex:1}
    .stream-bar-wrap{flex:2;height:4px;background:rgba(255,255,255,.06);border-radius:2px;overflow:hidden}
    .stream-bar{height:100%;background:linear-gradient(90deg,#6366f1,#818cf8);border-radius:2px;width:0;transition:width 1.2s ease}
    .stream-val{font-size:12px;color:#818cf8;font-weight:700;min-width:40px;text-align:right}
    .report-output{background:#0a0a14;border:1px solid rgba(255,255,255,.06);border-radius:14px;padding:16px;font-size:12px;line-height:1.8;color:rgba(255,255,255,.7);white-space:pre-wrap;max-height:280px;overflow-y:auto}
    .report-output::-webkit-scrollbar{width:3px}
    .report-output::-webkit-scrollbar-thumb{background:rgba(99,102,241,.3);border-radius:3px}

    /* ── NURTURING ── */
    .nurt-wrap{display:flex;flex-direction:column;gap:14px}
    .nurt-sequence{display:flex;flex-direction:column;gap:8px}
    .seq-item{display:flex;gap:12px;align-items:flex-start;opacity:0;transform:translateY(6px);transition:all .4s}
    .seq-item.show{opacity:1;transform:none}
    .seq-day{flex-shrink:0;width:48px;height:48px;background:rgba(99,102,241,.12);border:1px solid rgba(99,102,241,.2);border-radius:10px;display:flex;flex-direction:column;align-items:center;justify-content:center;font-size:10px;font-weight:700;color:#818cf8;text-align:center;line-height:1.2}
    .seq-content{background:#0a0a14;border:1px solid rgba(255,255,255,.06);border-radius:10px;padding:10px 12px;flex:1}
    .seq-trigger{font-size:10px;font-weight:600;color:rgba(255,255,255,.3);text-transform:uppercase;letter-spacing:.5px;margin-bottom:4px}
    .seq-msg{font-size:12px;color:rgba(255,255,255,.65);line-height:1.5}

    /* Misc */
    .form-row{margin-bottom:11px}
    .form-row label{display:block;font-size:12px;color:rgba(255,255,255,.4);margin-bottom:5px;font-weight:500}
    .form-row input,.form-row textarea,.form-row select{width:100%;background:#0a0a14;border:1px solid rgba(255,255,255,.08);border-radius:10px;padding:9px 13px;color:#fff;font-size:13px;outline:none;transition:border-color .2s;font-family:inherit}
    .form-row input:focus,.form-row textarea:focus,.form-row select:focus{border-color:#6366f1}
    .form-row textarea{resize:none;height:72px}
    .form-row select option{background:#111}
    .btn-run{width:100%;background:#6366f1;color:#fff;border:none;border-radius:10px;padding:11px;font-size:14px;font-weight:600;cursor:pointer;transition:background .2s;margin-top:4px}
    .btn-run:hover{background:#5558e8}
    .btn-run:disabled{background:#222;color:#555;cursor:not-allowed}
    .tag-label{font-size:10px;font-weight:700;color:#818cf8;text-transform:uppercase;letter-spacing:.5px;margin-bottom:6px}
  </style>
</head>
<body>

<!-- ── HERO ── -->
<section class="hero">
  <canvas id="network-canvas"></canvas>
  <div class="hero-content">
    <div class="hero-badge"><span class="dot-pulse"></span> Automatizaciones en vivo</div>
    <h1>La IA que trabaja<br><span>mientras tú descansas</span></h1>
    <p>Simula cada automatización en tiempo real. Ve exactamente cómo funciona antes de comprarlo.</p>
    <a href="#biblioteca" class="btn-hero">
      Probar Demos
      <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
    </a>
    <span class="scroll-hint">scroll para explorar</span>
  </div>
</section>

<!-- ── LIBRARY ── -->
<section class="library" id="biblioteca">
  <div class="library-hdr">
    <h2>Biblioteca de Automatizaciones</h2>
    <p>Simulaciones completas — desde que el cliente escribe hasta que la empresa recibe la notificación.</p>
  </div>

  <div class="demos-grid">

    <!-- ════════════════════════════════════════════════
         DEMO 1 — CALIFICACIÓN DE LEADS
    ════════════════════════════════════════════════ -->
    <div class="demo-card" id="card-leads">
      <div class="card-hdr">
        <div class="card-icon">🎯</div>
        <div class="card-meta">
          <div class="card-title">Calificación de Leads</div>
          <div class="card-desc">Bot captura datos con preguntas → IA califica → empresa recibe notificación.</div>
        </div>
        <div class="card-price">$3,000</div>
      </div>

      <div class="demo-idle" id="idle-leads">
        <div class="demo-idle-desc" style="padding:16px 22px 0">Ve cómo el bot conduce la conversación, extrae la información clave y en segundos califica al lead y te avisa por WhatsApp.</div>
        <div style="padding:14px 22px 20px">
          <button class="btn-start" onclick="startDemo('leads')">▶ Iniciar simulación</button>
        </div>
      </div>

      <div class="demo-active" id="active-leads">
        <div class="steps-bar">
          <div class="step-item current" id="step-leads-1">1. Chat del bot</div>
          <div class="step-item" id="step-leads-2">2. Análisis IA</div>
          <div class="step-item" id="step-leads-3">3. Notificación</div>
        </div>

        <!-- Phase 1: Chat -->
        <div class="phase active" id="phase-leads-1">
          <div class="chat-window">
            <div class="chat-header">
              <div class="chat-avatar">🤖</div>
              <div>
                <div class="chat-bot-name">Asistente Klimze</div>
                <div class="chat-bot-status"><span class="online-dot"></span>En línea</div>
              </div>
            </div>
            <div class="chat-messages" id="msgs-leads"></div>
            <div class="chat-input-row">
              <input class="chat-input" id="input-leads" placeholder="Escribe tu respuesta..." onkeydown="if(event.key==='Enter')sendChat('leads')" />
              <button class="chat-send" id="send-leads" onclick="sendChat('leads')">
                <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="white" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M22 2L11 13M22 2l-7 20-4-9-9-4 20-7z"/></svg>
              </button>
            </div>
          </div>
        </div>

        <!-- Phase 2: Analysis -->
        <div class="phase" id="phase-leads-2">
          <div class="analysis-wrap">
            <div class="analysis-ring"></div>
            <div class="analysis-label">Analizando prospecto con IA...</div>
            <div class="analysis-steps">
              <div class="astep" id="astep-leads-1"><div class="astep-dot"></div>Procesando información del lead</div>
              <div class="astep" id="astep-leads-2"><div class="astep-dot"></div>Evaluando intención de compra</div>
              <div class="astep" id="astep-leads-3"><div class="astep-dot"></div>Calculando score de prioridad</div>
              <div class="astep" id="astep-leads-4"><div class="astep-dot"></div>Generando respuesta personalizada</div>
            </div>
          </div>
        </div>

        <!-- Phase 3: Notification -->
        <div class="phase" id="phase-leads-3">
          <div class="notif-wrap">
            <div class="notif-label">📱 Notificación recibida por la empresa</div>
            <div class="notif-phone">
              <div class="notif-phone-bar">
                <div class="notif-app-icon">💬</div>
                <div class="notif-app-name">WhatsApp Business</div>
                <div class="notif-time">Ahora</div>
              </div>
              <div class="notif-body" id="notif-leads-body">
                <!-- filled by JS -->
              </div>
            </div>
            <button class="reset-btn" onclick="resetDemo('leads')">↺ Reiniciar demo</button>
          </div>
        </div>
      </div>
    </div>

    <!-- ════════════════════════════════════════════════
         DEMO 2 — PIPELINE DE VENTAS
    ════════════════════════════════════════════════ -->
    <div class="demo-card" id="card-pipeline">
      <div class="card-hdr">
        <div class="card-icon">🚀</div>
        <div class="card-meta">
          <div class="card-title">Pipeline de Ventas</div>
          <div class="card-desc">Lead entra → se mueve por etapas → mensaje automático en cada paso.</div>
        </div>
        <div class="card-price">$7,500</div>
      </div>

      <div class="demo-idle" id="idle-pipeline">
        <div class="demo-idle-desc" style="padding:16px 22px 0">Ve cómo un lead avanza automáticamente por el pipeline y recibe el mensaje correcto en el momento correcto, sin que nadie lo gestione manualmente.</div>
        <div style="padding:14px 22px 20px">
          <div class="form-row"><label>Tipo de negocio</label><input id="pipe-biz" placeholder="Ej: Clínica dental en Panamá" /></div>
          <div class="form-row"><label>Nombre del lead de prueba</label><input id="pipe-name" placeholder="Ej: Carlos López" /></div>
          <button class="btn-start" onclick="startDemo('pipeline')">▶ Iniciar simulación</button>
        </div>
      </div>

      <div class="demo-active" id="active-pipeline">
        <div class="steps-bar">
          <div class="step-item current" id="step-pipeline-1">1. Lead entra</div>
          <div class="step-item" id="step-pipeline-2">2. Pipeline</div>
          <div class="step-item" id="step-pipeline-3">3. Secuencia</div>
        </div>
