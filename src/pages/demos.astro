<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Demos — Klimze Automatizaciones</title>
  <style>
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;background:#06060e;color:#fff;overflow-x:hidden}
    #network-canvas{position:fixed;inset:0;width:100%;height:100%;z-index:0;pointer-events:none}

    /* ── HERO ── */
    .hero{position:relative;min-height:100vh;display:flex;align-items:center;justify-content:center;z-index:1}
    .hero-content{text-align:center;display:flex;flex-direction:column;align-items:center;gap:26px;padding:0 24px}
    .hero-badge{display:inline-flex;align-items:center;gap:7px;background:rgba(99,102,241,.12);border:1px solid rgba(99,102,241,.3);color:#a5b4fc;font-size:12px;font-weight:600;padding:5px 14px;border-radius:20px;letter-spacing:.5px}
    .dot-pulse{width:6px;height:6px;background:#7c7cff;border-radius:50%;animation:pulse 1.5s infinite}
    @keyframes pulse{0%,100%{opacity:1;transform:scale(1)}50%{opacity:.4;transform:scale(.8)}}
    .hero h1{font-size:clamp(32px,5.5vw,66px);font-weight:800;line-height:1.08;letter-spacing:-.03em;max-width:700px}
    .hero h1 span{background:linear-gradient(135deg,#818cf8,#60a5fa);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
    .hero p{color:rgba(255,255,255,.42);font-size:17px;max-width:430px;line-height:1.65}
    .btn-hero{display:inline-flex;align-items:center;gap:10px;background:#6366f1;color:#fff;border:none;border-radius:14px;padding:17px 44px;font-size:17px;font-weight:700;cursor:pointer;transition:all .2s;text-decoration:none;box-shadow:0 0 50px rgba(99,102,241,.45),0 8px 32px rgba(0,0,0,.4)}
    .btn-hero:hover{background:#5558e8;transform:translateY(-2px);box-shadow:0 0 70px rgba(99,102,241,.6),0 12px 40px rgba(0,0,0,.5)}
    .scroll-hint{color:rgba(255,255,255,.18);font-size:11px;letter-spacing:2px;text-transform:uppercase}

    /* ── STATS STRIP ── */
    .stats-strip{position:relative;z-index:1;padding:0 24px;margin-bottom:0}
    .stats-inner{max-width:900px;margin:0 auto;display:flex;align-items:center;justify-content:center;gap:0;background:rgba(99,102,241,.07);backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px);border:1px solid rgba(99,102,241,.15);border-radius:20px;padding:28px 40px;box-shadow:0 0 60px rgba(99,102,241,.08),inset 0 1px 0 rgba(255,255,255,.05)}
    .stat-item{flex:1;text-align:center;padding:0 20px}
    .stat-number{font-size:32px;font-weight:900;letter-spacing:-.03em;background:linear-gradient(135deg,#818cf8,#60a5fa);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;line-height:1}
    .stat-label{font-size:11px;color:rgba(255,255,255,.35);font-weight:500;margin-top:6px;letter-spacing:.3px}
    .stat-divider{width:1px;height:40px;background:rgba(255,255,255,.07);flex-shrink:0}

    /* ── LIBRARY ── */
    .library{position:relative;z-index:1;padding:110px 24px 140px}
    .library-inner{max-width:1160px;margin:0 auto}
    .library-hdr{text-align:center;margin-bottom:68px}
    .library-hdr h2{font-size:clamp(22px,3.5vw,40px);font-weight:800;margin-bottom:10px;letter-spacing:-.02em}
    .library-hdr p{color:rgba(255,255,255,.32);font-size:15px}

    /* ── PRICING GRID ── */
    .pricing-grid{display:flex;flex-wrap:wrap;gap:24px;justify-content:center}

    /* ── PRICING CARD ── */
    .pricing-card{
      position:relative;flex:0 0 calc(33.33% - 16px);min-width:280px;max-width:360px;
      background:rgba(120,130,255,.07);backdrop-filter:blur(28px) saturate(1.4);-webkit-backdrop-filter:blur(28px) saturate(1.4);
      border:none;border-radius:24px;
      padding:36px 28px 28px;display:flex;flex-direction:column;
      transition:all .3s ease;
      box-shadow:0 8px 40px rgba(0,0,0,.4),inset 0 1px 0 rgba(255,255,255,.06);
    }
    .pricing-card:hover{
      background:rgba(120,130,255,.11);transform:translateY(-6px);
      box-shadow:0 28px 70px rgba(0,0,0,.5),0 0 40px rgba(99,102,241,.12),inset 0 1px 0 rgba(255,255,255,.08)
    }
    .pricing-card.popular{
      background:rgba(99,102,241,.16);backdrop-filter:blur(28px) saturate(1.6);-webkit-backdrop-filter:blur(28px) saturate(1.6);
      box-shadow:0 0 60px rgba(99,102,241,.2),0 8px 40px rgba(0,0,0,.45),inset 0 1px 0 rgba(129,140,248,.15)
    }
    .pricing-card.popular:hover{background:rgba(99,102,241,.22);box-shadow:0 28px 90px rgba(0,0,0,.55),0 0 80px rgba(99,102,241,.3),inset 0 1px 0 rgba(129,140,248,.2)}

    .popular-badge{
      position:absolute;top:-14px;left:50%;transform:translateX(-50%);
      background:linear-gradient(135deg,#6366f1,#818cf8);color:#fff;
      font-size:11px;font-weight:700;padding:4px 18px;border-radius:20px;
      letter-spacing:.5px;white-space:nowrap;box-shadow:0 4px 16px rgba(99,102,241,.5)
    }

    .card-icon{font-size:34px;margin-bottom:18px}
    .card-name{font-size:20px;font-weight:800;margin-bottom:6px;letter-spacing:-.01em}
    .card-tagline{color:rgba(255,255,255,.4);font-size:13px;line-height:1.55;margin-bottom:22px}
    .price-row{margin-bottom:22px}
    .price-amount{font-size:46px;font-weight:900;letter-spacing:-.04em;line-height:1}
    .popular .price-amount{background:linear-gradient(135deg,#818cf8,#60a5fa);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
    .price-period{font-size:14px;color:rgba(255,255,255,.35);font-weight:400}
    .card-divider{height:1px;background:rgba(255,255,255,.06);margin-bottom:22px}

    .card-features{list-style:none;display:flex;flex-direction:column;gap:12px;margin-bottom:28px;flex:1}
    .card-features li{display:flex;align-items:flex-start;gap:10px;font-size:13.5px;color:rgba(255,255,255,.68);line-height:1.45}
    .feat-check{width:18px;height:18px;background:rgba(99,102,241,.18);border:1px solid rgba(99,102,241,.35);border-radius:5px;display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-top:1px}
    .popular .feat-check{background:rgba(99,102,241,.28);border-color:rgba(129,140,248,.55)}

    .card-btn{display:block;text-align:center;text-decoration:none;padding:14px;border-radius:12px;font-size:14px;font-weight:700;transition:all .2s;letter-spacing:.2px}
    .btn-outline{background:transparent;border:1px solid rgba(99,102,241,.35);color:rgba(255,255,255,.78)}
    .btn-outline:hover{background:rgba(99,102,241,.12);border-color:rgba(99,102,241,.6);color:#fff;transform:none}
    .btn-primary{background:linear-gradient(135deg,#6366f1,#818cf8);color:#fff;border:none;box-shadow:0 4px 20px rgba(99,102,241,.42)}
    .btn-primary:hover{box-shadow:0 6px 32px rgba(99,102,241,.65);transform:translateY(-1px)}
  </style>
</head>
<body>

<canvas id="network-canvas"></canvas>

