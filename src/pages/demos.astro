          <div class="card-icon">🚀</div>
          <div class="card-meta">
            <div class="card-title">Pipeline de Ventas</div>
            <div class="card-desc">Genera una secuencia completa de seguimiento para un lead.</div>
          </div>
          <div class="card-price">$7,500</div>
        </div>
        <div class="card-body">
          <label>Tipo de negocio</label>
          <input type="text" id="pipe-negocio" placeholder="Ej: Clínica dental en Ciudad de Panamá" />
          <label>Problema principal del cliente</label>
