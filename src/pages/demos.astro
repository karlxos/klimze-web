<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Demos en Vivo — Klimze</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      background: #06060e;
      color: #fff;
      overflow-x: hidden;
    }

    /* ── HERO ── */
    .hero {
      position: relative;
      width: 100%;
      height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
    }
    #network-canvas {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
    }
    .hero-content {
      position: relative;
      z-index: 10;
      text-align: center;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 28px;
    }
    .hero-badge {
      display: inline-flex;
      align-items: center;
      gap: 7px;
      background: rgba(99,102,241,0.12);
      border: 1px solid rgba(99,102,241,0.3);
      color: #a5b4fc;
      font-size: 12px;
      font-weight: 600;
      padding: 5px 14px;
      border-radius: 20px;
      letter-spacing: 0.5px;
    }
    .dot-pulse {
      width: 6px; height: 6px;
      background: #7c7cff;
      border-radius: 50%;
      animation: pulse 1.5s infinite;
    }
    @keyframes pulse { 0%,100%{opacity:1;transform:scale(1)} 50%{opacity:.4;transform:scale(0.8)} }
    .hero h1 {
      font-size: clamp(28px, 5vw, 56px);
      font-weight: 800;
      line-height: 1.15;
      letter-spacing: -0.02em;
      color: #fff;
      max-width: 640px;
    }
    .hero h1 span {
      background: linear-gradient(135deg, #818cf8, #60a5fa);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }
    .hero p {
      color: rgba(255,255,255,0.45);
      font-size: 16px;
      max-width: 400px;
      line-height: 1.6;
    }
    .btn-primary {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      background: #6366f1;
      color: #fff;
      border: none;
      border-radius: 14px;
      padding: 16px 36px;
      font-size: 16px;
      font-weight: 700;
      cursor: pointer;
      transition: all 0.2s;
      text-decoration: none;
      box-shadow: 0 0 40px rgba(99,102,241,0.4), 0 8px 32px rgba(0,0,0,0.4);
    }
    .btn-primary:hover {
      background: #5558e8;
      transform: translateY(-2px);
      box-shadow: 0 0 60px rgba(99,102,241,0.55), 0 12px 40px rgba(0,0,0,0.5);
    }
    .btn-primary svg { transition: transform 0.2s; }
    .btn-primary:hover svg { transform: translateY(3px); }
    .scroll-hint {
      color: rgba(255,255,255,0.2);
      font-size: 12px;
      letter-spacing: 2px;
      text-transform: uppercase;
    }

    /* ── LIBRARY ── */
    .library {
      padding: 80px 24px 100px;
      max-width: 1100px;
      margin: 0 auto;
    }
    .library-header {
      text-align: center;
      margin-bottom: 56px;
    }
    .library-header h2 {
      font-size: clamp(22px, 3.5vw, 36px);
      font-weight: 800;
      margin-bottom: 10px;
    }
    .library-header p {
      color: rgba(255,255,255,0.4);
      font-size: 15px;
    }

    .demos-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
      gap: 20px;
    }

    /* ── DEMO CARD ── */
    .demo-card {
      background: #0f0f1a;
      border: 1px solid rgba(99,102,241,0.15);
      border-radius: 18px;
      overflow: hidden;
      transition: border-color 0.2s, transform 0.2s;
    }
    .demo-card:hover { border-color: rgba(99,102,241,0.4); transform: translateY(-2px); }
    .card-header {
      padding: 22px 22px 18px;
      border-bottom: 1px solid rgba(255,255,255,0.05);
      display: flex;
      align-items: flex-start;
      gap: 14px;
    }
    .card-icon {
      font-size: 28px;
      line-height: 1;
      flex-shrink: 0;
      margin-top: 2px;
    }
    .card-meta { flex: 1; }
    .card-title { font-weight: 700; font-size: 15px; margin-bottom: 3px; }
    .card-desc { color: rgba(255,255,255,0.4); font-size: 13px; line-height: 1.5; }
    .card-price {
      font-size: 11px;
      font-weight: 700;
      color: #818cf8;
      background: rgba(99,102,241,0.1);
      border: 1px solid rgba(99,102,241,0.2);
      padding: 2px 9px;
      border-radius: 20px;
      white-space: nowrap;
    }

    .card-body { padding: 18px 22px 22px; }

    label {
      display: block;
      font-size: 12px;
      color: rgba(255,255,255,0.45);
      margin-bottom: 5px;
      font-weight: 500;
    }
    input, textarea, select {
      width: 100%;
      background: #0a0a14;
      border: 1px solid rgba(255,255,255,0.08);
      border-radius: 10px;
      padding: 10px 13px;
      color: #fff;
      font-size: 14px;
      margin-bottom: 11px;
      outline: none;
      transition: border-color 0.2s;
      font-family: inherit;
    }
    input:focus, textarea:focus, select:focus { border-color: #6366f1; }
    textarea { resize: none; height: 80px; }
    select option { background: #111; }

    .btn-run {
      width: 100%;
      background: #6366f1;
      color: #fff;
      border: none;
      border-radius: 10px;
      padding: 12px;
      font-size: 14px;
      font-weight: 600;
      cursor: pointer;
      transition: background 0.2s;
      margin-top: 2px;
    }
    .btn-run:hover { background: #5558e8; }
    .btn-run:disabled { background: #222; color: #555; cursor: not-allowed; }

    .result-box {
      display: none;
      margin-top: 14px;
      background: rgba(99,102,241,0.06);
      border: 1px solid rgba(99,102,241,0.18);
      border-radius: 12px;
      padding: 14px 16px;
      font-size: 13px;
      color: rgba(255,255,255,0.8);
      line-height: 1.65;
      white-space: pre-wrap;
    }
    .result-box.show { display: block; }
    .result-label {
      font-size: 10px;
      font-weight: 700;
      color: #6366f1;
      text-transform: uppercase;
      letter-spacing: 1px;
      margin-bottom: 7px;
    }

    /* lead card special */
    .lead-verdict {
      display: none;
      margin-top: 14px;
      border-radius: 12px;
      padding: 14px 16px;
      border: 1px solid;
    }
    .lead-verdict.calificado { background: #0d1f12; border-color: #1a4d2e; }
    .lead-verdict.no-calificado { background: #1f0d0d; border-color: #4d1a1a; }
    .lead-verdict.show { display: block; }
    .verdict-row { display: flex; align-items: center; gap: 8px; margin-bottom: 8px; }
    .verdict-icon { font-size: 18px; }
    .verdict-title { font-weight: 700; font-size: 14px; }
    .verdict-prio {
      font-size: 11px; font-weight: 600;
      padding: 2px 9px; border-radius: 20px;
    }
    .prio-alta { background: rgba(255,77,77,0.13); color: #ff6b6b; border: 1px solid rgba(255,77,77,0.25); }
    .prio-media { background: rgba(255,165,0,0.13); color: #ffb84d; border: 1px solid rgba(255,165,0,0.25); }
    .prio-baja { background: rgba(120,120,120,0.13); color: #888; border: 1px solid rgba(120,120,120,0.25); }
    .verdict-razon { color: rgba(255,255,255,0.55); font-size: 12px; margin-bottom: 10px; }
    .verdict-respuesta-label { font-size: 10px; color: #555; font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 5px; }
    .verdict-respuesta { font-size: 13px; color: rgba(255,255,255,0.75); line-height: 1.6; }

    .spinner-text {
      display: none;
      text-align: center;
      padding: 10px 0 0;
      color: rgba(255,255,255,0.35);
      font-size: 13px;
    }
    .spinner-text.show { display: block; }
  </style>
</head>
