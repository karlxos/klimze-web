<script>
// ── Groq proxy ──────────────────────────────────────────
async function groq(prompt, temp=0.7) {
  const r = await fetch('/api/groq', {
    method:'POST', headers:{'Content-Type':'application/json'},
    body: JSON.stringify({ model:'llama-3.3-70b-versatile', messages:[{role:'user',content:prompt}], temperature:temp })
  });
  const d = await r.json();
  return d.choices[0].message.content;
}

// ── Helpers ─────────────────────────────────────────────
function setPhase(demo, n) {
  document.querySelectorAll(`#active-${demo} .phase`).forEach((p,i)=>{
    p.classList.toggle('active', i===n-1);
  });
  document.querySelectorAll(`#active-${demo} .step-item`).forEach((s,i)=>{
    s.className='step-item'+(i<n-1?' done':i===n-1?' current':'');
  });
}
function startDemo(demo) {
  const card=document.getElementById(`card-${demo}`);
  card.classList.add('active');
  card.scrollIntoView({behavior:'smooth',block:'start'});
  setTimeout(()=>_init[demo]&&_init[demo](), 100);
}
function resetDemo(demo) {
  const card=document.getElementById(`card-${demo}`);
  card.classList.remove('active');
  _state[demo]={};
  _reset[demo]&&_reset[demo]();
}
function sleep(ms){return new Promise(r=>setTimeout(r,ms))}
async function animateSteps(steps, delay=600){
  for(let i=0;i<steps.length;i++){
    await sleep(delay);
    const el=document.getElementById(steps[i]);
    if(el){el.classList.add('active');await sleep(delay);el.classList.add('done');el.classList.remove('active')}
  }
}
function typewriter(el, text, speed=18){
  return new Promise(res=>{
    let i=0;el.textContent='';
    const t=setInterval(()=>{
      el.textContent+=text[i++];
      if(i>=text.length){clearInterval(t);res()}
    },speed);
  });
}

const _state={leads:{},pipeline:{},nurt:{},content:{},report:{}};
const _init={}, _reset={};

// ══════════════════════════════════════════════════════
// DEMO 1 — LEAD QUALIFICATION CHAT
// ══════════════════════════════════════════════════════
const LEAD_SCRIPT = [
  "¡Hola! 👋 Soy el asistente virtual. ¿Con quién tengo el gusto?",
  (n)=>`¡Mucho gusto, ${n}! 😊 ¿A qué se dedica tu negocio o empresa?`,
  ()=>`Perfecto! ¿Qué es lo que más quieres mejorar actualmente?\n\n🔹 Conseguir más clientes\n🔹 Automatizar procesos\n🔹 Ambos`,
  ()=>`¿Tienes algún presupuesto mensual en mente? (puede ser un rango aproximado)`,
  ()=>`Última pregunta: ¿cuándo te gustaría empezar?`,
  ()=>`Gracias por la información. Dame un momento, voy a revisar tu perfil con nuestro equipo... ⏳`,
];
const LEAD_FIELDS = [null,'nombre','negocio','objetivo','presupuesto','urgencia'];

_init.leads = function() {
  _state.leads = {step:0, data:{}};
  document.getElementById('msgs-leads').innerHTML='';
  setPhase('leads',1);
  setTimeout(()=>botMsg('leads', LEAD_SCRIPT[0]), 600);
};
_reset.leads = function() {
  document.getElementById('msgs-leads').innerHTML='';
  document.getElementById('notif-leads-body').innerHTML='';
};

function botMsg(demo, text){
  const msgs=document.getElementById(`msgs-${demo}`);
  const typing=document.createElement('div');
  typing.className='typing';typing.innerHTML='<span></span><span></span><span></span>';
  msgs.appendChild(typing);msgs.scrollTop=msgs.scrollHeight;
  return new Promise(res=>setTimeout(()=>{
    typing.remove();
    const m=document.createElement('div');
    m.className='msg bot';m.textContent=text;
    msgs.appendChild(m);msgs.scrollTop=msgs.scrollHeight;res();
  },1200));
}
function userMsg(demo, text){
  const msgs=document.getElementById(`msgs-${demo}`);
  const m=document.createElement('div');m.className='msg user';m.textContent=text;
  msgs.appendChild(m);msgs.scrollTop=msgs.scrollHeight;
}

async function sendChat(demo) {
  if(demo!=='leads')return;
  const inp=document.getElementById('input-leads');
  const val=inp.value.trim(); if(!val)return;
  const s=_state.leads;
  inp.value='';
  userMsg('leads',val);
  s.step++;
  const field=LEAD_FIELDS[s.step];
  if(field)s.data[field]=val;
  if(s.step>=5){
    document.getElementById('input-leads').disabled=true;
    document.getElementById('send-leads').disabled=true;
    const lastBot=LEAD_SCRIPT[5];
    await botMsg('leads', typeof lastBot==='function'?lastBot():lastBot);
    await sleep(1400);
    setPhase('leads',2);
    await runLeadsAnalysis(s.data);
    return;
  }
  const next=LEAD_SCRIPT[s.step];
  await botMsg('leads', typeof next==='function'?next(val):next);
  document.getElementById('input-leads').focus();
}

async function runLeadsAnalysis(data) {
  const steps=['astep-leads-1','astep-leads-2','astep-leads-3','astep-leads-4'];
  animateSteps(steps, 650);
  await sleep(200);
  const prompt=`Eres un calificador de leads para una agencia de automatizaciones en Panamá. Analiza y responde SOLO JSON sin markdown:
{"calificado":true/false,"prioridad":"alta/media/baja","razon":"string corto","respuesta":"mensaje personalizado en español"}

Datos: nombre=${data.nombre||'?'}, negocio=${data.negocio||'?'}, objetivo=${data.objetivo||'?'}, presupuesto=${data.presupuesto||'?'}, urgencia=${data.urgencia||'?'}`;
  const raw=await groq(prompt,.3);
  let cal;
  try{cal=JSON.parse(raw.replace(/```json\n?/g,'').replace(/```/g,'').trim())}
  catch{cal={calificado:true,prioridad:'alta',razon:'Lead con buena intención de compra',respuesta:`Hola ${data.nombre||''}! Me alegra que te hayas comunicado. Tenemos exactamente lo que buscas. ¿Podemos agendar una llamada rápida esta semana?`}}
  await sleep(2800);
  buildLeadsNotification(data, cal);
  setPhase('leads',3);
}

function buildLeadsNotification(data, cal) {
  const prioColor=cal.prioridad==='alta'?'#ff6b6b':cal.prioridad==='media'?'#ffb84d':'#888';
  const icon=cal.calificado?'✅':'❌';
  const title=cal.calificado?'🔔 NUEVO LEAD CALIFICADO':'⚠️ LEAD NO CALIFICADO';
  document.getElementById('notif-leads-body').innerHTML=`
    <div class="notif-title">${title}</div>
    <div class="notif-line"><strong>👤</strong> ${data.nombre||'—'}</div>
    <div class="notif-line"><strong>🏪</strong> ${data.negocio||'—'}</div>
    <div class="notif-line"><strong>🎯</strong> ${data.objetivo||'—'}</div>
    <div class="notif-line"><strong>💰</strong> ${data.presupuesto||'—'}</div>
    <div class="notif-line"><strong>⚡</strong> ${data.urgencia||'—'}</div>
    <div class="notif-divider"></div>
    <div class="notif-line">${icon} <strong style="color:${prioColor}">Prioridad ${cal.prioridad?.toUpperCase()}</strong></div>
    <div class="notif-line" style="font-size:12px;color:rgba(255,255,255,.45);margin-top:2px">${cal.razon||''}</div>
    <div class="notif-divider"></div>
    <div class="notif-suggestion">
      <div class="notif-suggestion-label">💬 Respuesta sugerida</div>
      ${cal.respuesta||''}
    </div>`;
}

// ══════════════════════════════════════════════════════
// DEMO 2 — PIPELINE
// ══════════════════════════════════════════════════════
const PIPE_STAGES = ['Nuevo','Contactado','Interesado','Propuesta','Cerrado'];
_init.pipeline = function(){
  _state.pipeline={step:0, biz:document.getElementById('pipe-biz').value||'negocio local', name:document.getElementById('pipe-name').value||'Carlos López', msgs:[], stage:0};
  setPhase('pipeline',1);
  document.getElementById('pipe-lead-name-show').textContent=_state.pipeline.name;
  setTimeout(()=>runPipelineGen(),800);
};
_reset.pipeline=function(){document.getElementById('pipe-board').innerHTML='';document.getElementById('pipe-sequence').innerHTML=''};

async function runPipelineGen(){
  const {biz,name}=_state.pipeline;
  const prompt=`Para el negocio "${biz}", crea 5 mensajes de WhatsApp cortos (máx 2 líneas c/u) para un pipeline de ventas: Contacto inicial, Seguimiento, Oferta de valor, Propuesta concreta, Cierre. Lead: ${name}. Responde SOLO JSON: [{"etapa":"nombre","mensaje":"texto"},...] sin markdown.`;
  const raw=await groq(prompt,.5);
  let msgs;
  try{msgs=JSON.parse(raw.replace(/```json\n?/g,'').replace(/```/g,'').trim())}
  catch{msgs=PIPE_STAGES.map((e,i)=>({etapa:e,mensaje:`Hola ${name}! ${['¿Cómo podemos ayudarte?','¿Tuviste oportunidad de revisar?','Tenemos una solución ideal para ti.','Te envío la propuesta personalizada.','¿Cuándo empezamos?'][i]}`}))}
  _state.pipeline.msgs=msgs;
  buildPipelineBoard(name,msgs);
  setPhase('pipeline',2);
}
function buildPipelineBoard(name,msgs){
  const board=document.getElementById('pipe-board');
  board.innerHTML='';
  PIPE_STAGES.forEach((s,i)=>{
    const col=document.createElement('div');col.className='pipe-col';
    col.innerHTML=`<div class="pipe-col-title">${s}</div>`;
    if(i===0){
      col.innerHTML+=`<div class="pipe-card highlight" id="pcard-${i}"><div class="pipe-card-name">${name}</div><div style="font-size:11px;color:rgba(255,255,255,.4)">Recién llegado</div></div>`;
    } else {
      col.innerHTML+=`<div class="pipe-card" id="pcard-${i}" style="opacity:.3"><div class="pipe-card-name" style="color:rgba(255,255,255,.3)">${name}</div></div>`;
    }
    board.appendChild(col);
  });
}
let pipeStage=0;
async function advancePipeline(){
  const {msgs,name}=_state.pipeline;
  pipeStage++;
  if(pipeStage>=PIPE_STAGES.length){
    setPhase('pipeline',3);
    buildPipelineSequence(msgs);
    return;
  }
  for(let i=0;i<PIPE_STAGES.length;i++){
    const c=document.getElementById(`pcard-${i}`);if(!c)continue;
    c.classList.toggle('highlight',i===pipeStage);
    c.style.opacity=i<=pipeStage?'1':'0.3';
    if(i===pipeStage){
      const msg=msgs[i]?.mensaje||'';
      c.innerHTML=`<div class="pipe-card-name">${name}</div><div class="pipe-msg-preview show"><div class="pipe-msg-label">📤 Enviado automáticamente</div>${msg}</div>`;
    }
  }
  if(pipeStage===PIPE_STAGES.length-1){
    document.getElementById('pipe-advance-btn').textContent='Ver secuencia completa →';
  }
}
function buildPipelineSequence(msgs){
  const seq=document.getElementById('pipe-sequence');seq.innerHTML='';
  const days=[1,3,7,14,30];
  msgs.forEach((m,i)=>{
    const it=document.createElement('div');it.className='seq-item';
    it.innerHTML=`<div class="seq-day">Día<br>${days[i]||i*7}</div><div class="seq-content"><div class="seq-trigger">${['Nuevo lead','Sin respuesta 2d','Interés mostrado','Propuesta vista','Sin cierre'][i]||'Automático'}</div><div class="seq-msg">${m.mensaje}</div></div>`;
    seq.appendChild(it);
    setTimeout(()=>it.classList.add('show'),i*300+100);
  });
}

// ══════════════════════════════════════════════════════
// DEMO 3 — NURTURING
// ══════════════════════════════════════════════════════
_init.nurt=function(){
  const biz=document.getElementById('nurt-biz').value||'negocio local';
  _state.nurt={biz,msgs:[],turn:0};
  document.getElementById('nurt-bot-name').textContent=`Bot de ${biz}`;
  document.getElementById('msgs-nurt').innerHTML='';
  setPhase('nurt',1);
  setTimeout(()=>botMsg('nurt',`¡Hola! 👋 Bienvenido a ${biz}. ¿En qué te podemos ayudar hoy?`),600);
};
_reset.nurt=function(){document.getElementById('msgs-nurt').innerHTML='';document.getElementById('nurt-sequence').innerHTML=''};

async function sendNurt(){
  const inp=document.getElementById('input-nurt');
  const val=inp.value.trim();if(!val)return;
  inp.value='';userMsg('nurt',val);
  _state.nurt.msgs.push({role:'user',content:val});_state.nurt.turn++;
  document.getElementById('send-nurt').disabled=true;
  const {biz,msgs}=_state.nurt;
  const history=msgs.map(m=>`${m.role==='user'?'Cliente':'Bot'}: ${m.content}`).join('\n');
  const prompt=`Eres el bot de WhatsApp de "${biz}". Responde al cliente de forma cálida y orientada a cerrar venta/agendar. Máx 3 líneas. Usa emojis sutiles. Español.\n\nConversación:\n${history}`;
  const reply=await groq(prompt,.8);
  _state.nurt.msgs.push({role:'bot',content:reply});
  await botMsg('nurt',reply);
  document.getElementById('send-nurt').disabled=false;
  document.getElementById('input-nurt').focus();
}

async function finishNurt(){
  setPhase('nurt',2);
  animateSteps(['nstep-1','nstep-2','nstep-3'],700);
  const {biz,msgs}=_state.nurt;
  const history=msgs.map(m=>`${m.role==='user'?'Cliente':'Bot'}: ${m.content}`).join('\n');
  const prompt=`Basado en esta conversación de WhatsApp para "${biz}", crea 4 mensajes de seguimiento automático (si el cliente deja de responder) para los días 1, 3, 7, 14. Responde SOLO JSON: [{"dia":1,"trigger":"...","mensaje":"..."},...] sin markdown.\n\n${history}`;
  const raw=await groq(prompt,.5);
  let seq;
  try{seq=JSON.parse(raw.replace(/```json\n?/g,'').replace(/```/g,'').trim())}
  catch{seq=[{dia:1,trigger:'Sin respuesta',mensaje:`¡Hola! Solo quería saber si pudiste revisar lo que hablamos 😊`},{dia:3,trigger:'Aún sin respuesta',mensaje:`Te escribo porque creo que ${biz} puede ayudarte mucho. ¿Tienes 5 minutos?`},{dia:7,trigger:'1 semana sin respuesta',mensaje:`Tenemos una oferta especial esta semana. ¿Quieres que te la cuente?`},{dia:14,trigger:'Reactivación',mensaje:`Hola! Han pasado unos días. ¿Cómo estás? Aquí seguimos si necesitas algo.`}]}
  await sleep(2500);
  buildNurtSequence(seq);
  setPhase('nurt',3);
}
function buildNurtSequence(seq){
  const el=document.getElementById('nurt-sequence');el.innerHTML='';
  seq.forEach((s,i)=>{
    const it=document.createElement('div');it.className='seq-item';
    it.innerHTML=`<div class="seq-day">Día<br>${s.dia||i+1}</div><div class="seq-content"><div class="seq-trigger">${s.trigger||'Automático'}</div><div class="seq-msg">${s.mensaje||''}</div></div>`;
    el.appendChild(it);
    setTimeout(()=>it.classList.add('show'),i*280+100);
  });
}

// ══════════════════════════════════════════════════════
// DEMO 4 — CONTENT GENERATION
// ══════════════════════════════════════════════════════
_init.content=async function(){
  const biz=document.getElementById('cont-biz').value||'negocio';
  const net=document.getElementById('cont-net').value||'Instagram';
  const topic=document.getElementById('cont-topic').value||'producto destacado';
  _state.content={biz,net,topic};
  setPhase('content',1);
  const prompt=`Crea un post de ${net} para "${biz}" sobre "${topic}". Gancho fuerte, emojis estratégicos, CTA claro. Listo para copiar y pegar. En español. Máx 200 palabras.`;
  const text=await groq(prompt,.8);
  _state.content.text=text;
  await sleep(300);
  setPhase('content',2);
  document.getElementById('cont-net-label').textContent=`📱 Post generado para ${net}`;
  const out=document.getElementById('cont-output');out.textContent='';
  await typewriter(out,text,16);
};
_reset.content=function(){document.getElementById('cont-output').textContent='';document.getElementById('cont-calendar').innerHTML=''};

async function scheduleContent(){
  setPhase('content',3);
  const {biz,net,text}=_state.content;
  const days=['Lunes','Miércoles','Viernes'];
  const times=['9:00 AM','12:00 PM','6:00 PM'];
  const grid=document.getElementById('cont-calendar');grid.innerHTML='';
  const prompt=`Genera 2 ideas adicionales de posts para "${biz}" en ${net} (títulos cortos, 5-8 palabras c/u). SOLO JSON: ["idea 1","idea 2"] sin markdown.`;
  const raw=await groq(prompt,.9);
  let ideas=[];
  try{ideas=JSON.parse(raw.replace(/```json\n?/g,'').replace(/```/g,'').trim())}
  catch{ideas=['Post sobre servicio destacado','Testimonio de cliente feliz']}
  const posts=[text.split('\n')[0].substring(0,60)+'...', ...ideas.map(s=>s.substring(0,60))];
  [0,1,2].forEach(i=>{
    const it=document.createElement('div');it.className='cal-item';
    it.innerHTML=`<div class="cal-day">${days[i]} ${times[i]}</div><div class="cal-text">${posts[i]||'Post programado'}</div><div class="cal-badge">Programado</div>`;
    grid.appendChild(it);
    setTimeout(()=>{it.style.opacity='0';it.style.transform='translateY(8px)';it.style.transition='all .4s';requestAnimationFrame(()=>{it.style.opacity='1';it.style.transform='none'})},i*200+100);
  });
}

// ══════════════════════════════════════════════════════
// DEMO 5 — WEEKLY REPORT
// ══════════════════════════════════════════════════════
const STREAMS=[
  {icon:'💬',name:'WhatsApp',val:null,key:'msgs'},
  {icon:'📅',name:'Citas agendadas',val:null,key:'citas'},
  {icon:'⭐',name:'Google Reviews',val:null,key:'reviews'},
  {icon:'💰',name:'Ventas',val:null,key:'ventas'},
  {icon:'📊',name:'Meta Ads',val:null,key:'ads'},
];
_init.report=async function(){
  const client=document.getElementById('rep-client').value||'Cliente';
  const metrics=document.getElementById('rep-metrics').value||'142 mensajes, 38 citas, 6 reseñas, ventas $4200';
  _state.report={client,metrics};
  setPhase('report',1);
  buildStreams();
  await animateStreams();
  await sleep(600);
  setPhase('report',2);
  const prompt=`Genera un reporte semanal ejecutivo profesional para "${client}". Incluye: Resumen ejecutivo, Highlights (3 puntos), Áreas de mejora (2 puntos), Acción recomendada para próxima semana. Español, tono profesional. Datos: ${metrics}`;
  const text=await groq(prompt,.5);
  _state.report.text=text;
  await sleep(400);
  setPhase('report',3);
  await typewriter(document.getElementById('rep-output'),text,8);
};
_reset.report=function(){document.getElementById('rep-streams').innerHTML='';document.getElementById('rep-output').textContent=''};

function buildStreams(){
  const el=document.getElementById('rep-streams');el.innerHTML='';
  const metrics=_state.report.metrics;
  const nums=metrics.match(/\d+[\.,]?\d*/g)||[];
  STREAMS.forEach((s,i)=>{
    const it=document.createElement('div');it.className='stream-item';it.id=`stream-${i}`;
    const v=nums[i]||Math.floor(Math.random()*200+20);
    it.innerHTML=`<div class="stream-icon">${s.icon}</div><div class="stream-name">${s.name}</div><div class="stream-bar-wrap"><div class="stream-bar" id="sbar-${i}"></div></div><div class="stream-val" id="sval-${i}">—</div>`;
    el.appendChild(it);
    _state.report[`val${i}`]=v;
  });
}
async function animateStreams(){
  for(let i=0;i<STREAMS.length;i++){
    await sleep(250);
    const bar=document.getElementById(`sbar-${i}`);
    const val=document.getElementById(`sval-${i}`);
    if(bar)bar.style.width=Math.min(100,20+i*15+Math.random()*30)+'%';
    if(val)val.textContent=_state.report[`val${i}`];
  }
  await sleep(800);
}
</script>
