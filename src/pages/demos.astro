  <!-- ── CANVAS ANIMATION ──────────────────────────────────────────────────── -->
  <script>
    (function () {
      const canvas = document.getElementById('network-canvas');
      const ctx = canvas.getContext('2d');
      let W, H, nodes = [];
      const NODE_COUNT = 70;
      const MAX_DIST = 180;
      const SPEED = 0.4;

      function resize() {
        W = canvas.width = window.innerWidth;
        H = canvas.height = window.innerHeight;
      }

      function initNodes() {
        nodes = [];
        for (let i = 0; i < NODE_COUNT; i++) {
          nodes.push({
            x: Math.random() * W,
            y: Math.random() * H,
            vx: (Math.random() - 0.5) * SPEED,
            vy: (Math.random() - 0.5) * SPEED,
            r: Math.random() * 2 + 1.2,
            opacity: Math.random() * 0.5 + 0.4,
          });
        }
      }

      function draw() {
        ctx.clearRect(0, 0, W, H);

        // connections
        for (let i = 0; i < nodes.length; i++) {
          for (let j = i + 1; j < nodes.length; j++) {
            const dx = nodes[j].x - nodes[i].x;
            const dy = nodes[j].y - nodes[i].y;
            const dist = Math.sqrt(dx * dx + dy * dy);
            if (dist < MAX_DIST) {
              const alpha = (1 - dist / MAX_DIST) * 0.35;
              const gradient = ctx.createLinearGradient(nodes[i].x, nodes[i].y, nodes[j].x, nodes[j].y);
              gradient.addColorStop(0, `rgba(99,102,241,${alpha})`);
              gradient.addColorStop(1, `rgba(96,165,250,${alpha})`);
              ctx.beginPath();
              ctx.moveTo(nodes[i].x, nodes[i].y);
              ctx.lineTo(nodes[j].x, nodes[j].y);
              ctx.strokeStyle = gradient;
              ctx.lineWidth = 0.8;
              ctx.stroke();
            }
          }
        }

        // nodes
        nodes.forEach(n => {
          // glow
          const grd = ctx.createRadialGradient(n.x, n.y, 0, n.x, n.y, n.r * 8);
          grd.addColorStop(0, `rgba(99,102,241,${n.opacity * 0.6})`);
          grd.addColorStop(1, 'rgba(99,102,241,0)');
          ctx.beginPath();
          ctx.arc(n.x, n.y, n.r * 8, 0, Math.PI * 2);
          ctx.fillStyle = grd;
          ctx.fill();

          // core
          ctx.beginPath();
          ctx.arc(n.x, n.y, n.r, 0, Math.PI * 2);
          ctx.fillStyle = `rgba(180,190,255,${n.opacity})`;
          ctx.fill();
        });
      }

      function update() {
        nodes.forEach(n => {
          n.x += n.vx;
          n.y += n.vy;
          if (n.x < 0 || n.x > W) n.vx *= -1;
          if (n.y < 0 || n.y > H) n.vy *= -1;
        });
      }

      function loop() {
        update();
        draw();
        requestAnimationFrame(loop);
      }

      window.addEventListener('resize', () => { resize(); });
      resize();
      initNodes();
      loop();
    })();

    // smooth scroll
    document.querySelector('.btn-primary').addEventListener('click', function(e) {
      e.preventDefault();
      document.getElementById('biblioteca').scrollIntoView({ behavior: 'smooth' });
    });
  </script>

  <!-- ── AI DEMOS ──────────────────────────────────────────────────────────── -->
  <script>
    async function groq(prompt) {
      const res = await fetch('/api/groq', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          model: 'llama-3.3-70b-versatile',
          messages: [{ role: 'user', content: prompt }],
          temperature: 0.7
        })
      });
      const data = await res.json();
      return data.choices[0].message.content;
    }

    function setLoading(btnId, spinnerId, loading) {
      const btn = document.getElementById(btnId);
      const sp = document.getElementById(spinnerId);
      btn.disabled = loading;
      loading ? sp.classList.add('show') : sp.classList.remove('show');
    }

    // ── 1. Lead Qualification ──────────────────────────────────────────────
    async function runLeadQual() {
      const nombre = document.getElementById('lead-nombre').value;
      const negocio = document.getElementById('lead-negocio').value;
      const mensaje = document.getElementById('lead-mensaje').value;
      if (!mensaje.trim()) { alert('Escribe el mensaje del prospecto.'); return; }
      setLoading('lead-btn', 'lead-spinner', true);
      const result = document.getElementById('lead-result');
      result.classList.remove('show', 'calificado', 'no-calificado');
      try {
        const prompt = `Eres un calificador de leads para una agencia de marketing digital en Panama. Analiza este prospecto y responde SOLO con un JSON valido sin markdown: {"calificado":true/false,"prioridad":"alta/media/baja","razon":"string corto","respuesta":"mensaje personalizado en espanol para enviarle al lead"}

Nombre: ${nombre || 'No indicado'}
Negocio: ${negocio || 'No indicado'}
Mensaje: ${mensaje}`;
        const raw = await groq(prompt);
        const clean = raw.replace(/```json\n?/g,'').replace(/```/g,'').trim();
        const cal = JSON.parse(clean);
        result.className = 'lead-verdict show ' + (cal.calificado ? 'calificado' : 'no-calificado');
        document.getElementById('lead-icon').textContent = cal.calificado ? '✅' : '❌';
        document.getElementById('lead-title').textContent = cal.calificado ? 'Lead Calificado' : 'Lead No Calificado';
        document.getElementById('lead-razon').textContent = cal.razon || '';
        document.getElementById('lead-respuesta').textContent = cal.respuesta || '';
        const prioEl = document.getElementById('lead-prio');
        prioEl.textContent = 'Prioridad ' + (cal.prioridad || '');
        prioEl.className = 'verdict-prio prio-' + (cal.prioridad || 'baja');
      } catch(e) { alert('Error al conectar. Intenta de nuevo.'); }
      finally { setLoading('lead-btn', 'lead-spinner', false); }
    }

    // ── 2. Pipeline de Ventas ─────────────────────────────────────────────
    async function runPipeline() {
      const negocio = document.getElementById('pipe-negocio').value;
      const problema = document.getElementById('pipe-problema').value;
      if (!negocio.trim()) { alert('Escribe el tipo de negocio.'); return; }
      setLoading('pipe-btn', 'pipe-spinner', true);
      document.getElementById('pipe-result').classList.remove('show');
      try {
        const prompt = `Eres un experto en automatizacion de ventas. Para el siguiente negocio, crea una secuencia de seguimiento de 5 pasos via WhatsApp (Dia 1, Dia 3, Dia 7, Dia 14, Dia 30). Cada mensaje debe ser corto, personalizado y orientado a conversión. Usa emojis sutiles. Responde en espanol.

Negocio: ${negocio}
Problema del cliente: ${problema || 'Capturar leads y convertirlos en clientes'}`;
        const text = await groq(prompt);
        document.getElementById('pipe-text').textContent = text;
        document.getElementById('pipe-result').classList.add('show');
      } catch(e) { alert('Error al conectar. Intenta de nuevo.'); }
      finally { setLoading('pipe-btn', 'pipe-spinner', false); }
    }

    // ── 3. Nurturing WhatsApp ─────────────────────────────────────────────
    async function runNurturing() {
      const negocio = document.getElementById('nurt-negocio').value;
      const mensaje = document.getElementById('nurt-mensaje').value;
      if (!mensaje.trim()) { alert('Escribe el mensaje del cliente.'); return; }
      setLoading('nurt-btn', 'nurt-spinner', true);
      document.getElementById('nurt-result').classList.remove('show');
      try {
        const prompt = `Eres un bot de WhatsApp de atención al cliente para un negocio tipo: ${negocio || 'negocio local'}. Responde al siguiente mensaje del cliente de manera cálida, profesional y orientada a cerrar la venta o agendar cita. Sé conciso (máximo 4 líneas). Usa emojis naturales. Responde en espanol.

Cliente dice: "${mensaje}"`;
        const text = await groq(prompt);
        document.getElementById('nurt-text').textContent = text;
        document.getElementById('nurt-result').classList.add('show');
      } catch(e) { alert('Error al conectar. Intenta de nuevo.'); }
      finally { setLoading('nurt-btn', 'nurt-spinner', false); }
    }

    // ── 4. Generación de Contenido ────────────────────────────────────────
    async function runContenido() {
      const negocio = document.getElementById('cont-negocio').value;
      const red = document.getElementById('cont-red').value;
      const tema = document.getElementById('cont-tema').value;
      if (!negocio.trim() || !tema.trim()) { alert('Completa negocio y tema.'); return; }
      setLoading('cont-btn', 'cont-spinner', true);
      document.getElementById('cont-result').classList.remove('show');
      try {
        const prompt = `Crea un post de ${red} para el siguiente negocio. Debe ser autentico, con gancho inicial fuerte, emojis estrategicos y call to action claro. Formato listo para copiar y pegar. En espanol.

Negocio: ${negocio}
Tema/Producto: ${tema}`;
        const text = await groq(prompt);
        document.getElementById('cont-text').textContent = text;
        document.getElementById('cont-result').classList.add('show');
      } catch(e) { alert('Error al conectar. Intenta de nuevo.'); }
      finally { setLoading('cont-btn', 'cont-spinner', false); }
    }

    // ── 5. Reporte Semanal ────────────────────────────────────────────────
    async function runReporte() {
      const cliente = document.getElementById('rep-cliente').value;
      const metricas = document.getElementById('rep-metricas').value;
      if (!metricas.trim()) { alert('Ingresa las métricas de la semana.'); return; }
      setLoading('rep-btn', 'rep-spinner', true);
      document.getElementById('rep-result').classList.remove('show');
      try {
        const prompt = `Eres un consultor de negocios. Genera un reporte semanal ejecutivo profesional para el siguiente cliente. Incluye: resumen ejecutivo, puntos clave, logros, areas de mejora y recomendacion de accion para la proxima semana. Usa formato limpio con secciones. En espanol.

Cliente: ${cliente || 'Cliente'}
Metricas de la semana: ${metricas}`;
        const text = await groq(prompt);
        document.getElementById('rep-text').textContent = text;
        document.getElementById('rep-result').classList.add('show');
      } catch(e) { alert('Error al conectar. Intenta de nuevo.'); }
      finally { setLoading('rep-btn', 'rep-spinner', false); }
    }
  </script>
</body>
</html>
