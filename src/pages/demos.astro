<script>
(function(){
  const c=document.getElementById('network-canvas'),ctx=c.getContext('2d');
  let W,H,nodes=[];
  const N=70,DIST=180,SPD=0.4;
  function resize(){W=c.width=innerWidth;H=c.height=innerHeight}
  function init(){nodes=[];for(let i=0;i<N;i++)nodes.push({x:Math.random()*W,y:Math.random()*H,vx:(Math.random()-.5)*SPD,vy:(Math.random()-.5)*SPD,r:Math.random()*2+1.2,o:Math.random()*.5+.4})}
  function draw(){
    ctx.clearRect(0,0,W,H);
    for(let i=0;i<nodes.length;i++)for(let j=i+1;j<nodes.length;j++){
      const dx=nodes[j].x-nodes[i].x,dy=nodes[j].y-nodes[i].y,d=Math.sqrt(dx*dx+dy*dy);
      if(d<DIST){const a=(1-d/DIST)*.35,g=ctx.createLinearGradient(nodes[i].x,nodes[i].y,nodes[j].x,nodes[j].y);g.addColorStop(0,`rgba(99,102,241,${a})`);g.addColorStop(1,`rgba(96,165,250,${a})`);ctx.beginPath();ctx.moveTo(nodes[i].x,nodes[i].y);ctx.lineTo(nodes[j].x,nodes[j].y);ctx.strokeStyle=g;ctx.lineWidth=.8;ctx.stroke()}
    }
    nodes.forEach(n=>{const g=ctx.createRadialGradient(n.x,n.y,0,n.x,n.y,n.r*8);g.addColorStop(0,`rgba(99,102,241,${n.o*.6})`);g.addColorStop(1,'rgba(99,102,241,0)');ctx.beginPath();ctx.arc(n.x,n.y,n.r*8,0,Math.PI*2);ctx.fillStyle=g;ctx.fill();ctx.beginPath();ctx.arc(n.x,n.y,n.r,0,Math.PI*2);ctx.fillStyle=`rgba(180,190,255,${n.o})`;ctx.fill()});
  }
  function update(){nodes.forEach(n=>{n.x+=n.vx;n.y+=n.vy;if(n.x<0||n.x>W)n.vx*=-1;if(n.y<0||n.y>H)n.vy*=-1})}
  function loop(){update();draw();requestAnimationFrame(loop)}
  addEventListener('resize',resize);resize();init();loop();
})();
document.querySelector('.btn-hero').addEventListener('click',e=>{e.preventDefault();document.getElementById('biblioteca').scrollIntoView({behavior:'smooth'})});
</script>

