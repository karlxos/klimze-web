<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Demos — Klimze Automatizaciones</title>
  <style>
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;background:#06060e;color:#fff;overflow-x:hidden}
    #network-canvas{position:fixed;inset:0;width:100%;height:100%;z-index:0;pointer-events:none}

    /* ── HERO ── */
    .hero{position:relative;min-height:100vh;display:flex;align-items:center;justify-content:center;z-index:1}
    .hero-content{text-align:center;display:flex;flex-direction:column;align-items:center;gap:26px;padding:0 24px}
    .hero-badge{display:inline-flex;align-items:center;gap:7px;background:rgba(99,102,241,.12);border:1px solid rgba(99,102,241,.3);color:#a5b4fc;font-size:12px;font-weight:600;padding:5px 14px;border-radius:20px;letter-spacing:.5px}
    .dot-pulse{width:6px;height:6px;background:#7c7cff;border-radius:50%;animation:pulse 1.5s infinite}
    @keyframes pulse{0%,100%{opacity:1;transform:scale(1)}50%{opacity:.4;transform:scale(.8)}}
    .hero h1{font-size:clamp(32px,5.5vw,66px);font-weight:800;line-height:1.08;letter-spacing:-.03em;max-width:700px}
    .hero h1 span{background:linear-gradient(135deg,#818cf8,#60a5fa);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
    .hero p{color:rgba(255,255,255,.42);font-size:17px;max-width:430px;line-height:1.65}
    .btn-hero{display:inline-flex;align-items:center;gap:10px;background:#6366f1;color:#fff;border:none;border-radius:14px;padding:17px 44px;font-size:17px;font-weight:700;cursor:pointer;transition:all .2s;text-decoration:none;box-shadow:0 0 50px rgba(99,102,241,.45),0 8px 32px rgba(0,0,0,.4)}
    .btn-hero:hover{background:#5558e8;transform:translateY(-2px);box-shadow:0 0 70px rgba(99,102,241,.6),0 12px 40px rgba(0,0,0,.5)}
    .scroll-hint{color:rgba(255,255,255,.18);font-size:11px;letter-spacing:2px;text-transform:uppercase}

    /* ── LIBRARY ── */
    .library{position:relative;z-index:1;padding:110px 24px 140px}
    .library-inner{max-width:1160px;margin:0 auto}
    .library-hdr{text-align:center;margin-bottom:68px}
    .library-hdr h2{font-size:clamp(22px,3.5vw,40px);font-weight:800;margin-bottom:10px;letter-spacing:-.02em}
    .library-hdr p{color:rgba(255,255,255,.32);font-size:15px}

    /* ── PRICING GRID ── */
    .pricing-grid{display:flex;flex-wrap:wrap;gap:24px;justify-content:center}

    /* ── PRICING CARD ── */
    .pricing-card{
      position:relative;flex:0 0 calc(33.33% - 16px);min-width:280px;max-width:360px;
      background:rgba(120,130,255,.07);backdrop-filter:blur(28px) saturate(1.4);-webkit-backdrop-filter:blur(28px) saturate(1.4);
      border:none;border-radius:24px;
      padding:36px 28px 28px;display:flex;flex-direction:column;
      transition:all .3s ease;
      box-shadow:0 8px 40px rgba(0,0,0,.4),inset 0 1px 0 rgba(255,255,255,.06);
    }
    .pricing-card:hover{
      background:rgba(120,130,255,.11);transform:translateY(-6px);
      box-shadow:0 28px 70px rgba(0,0,0,.5),0 0 40px rgba(99,102,241,.12),inset 0 1px 0 rgba(255,255,255,.08)
    }
    .pricing-card.popular{
      background:rgba(99,102,241,.16);backdrop-filter:blur(28px) saturate(1.6);-webkit-backdrop-filter:blur(28px) saturate(1.6);
      box-shadow:0 0 60px rgba(99,102,241,.2),0 8px 40px rgba(0,0,0,.45),inset 0 1px 0 rgba(129,140,248,.15)
    }
    .pricing-card.popular:hover{background:rgba(99,102,241,.22);box-shadow:0 28px 90px rgba(0,0,0,.55),0 0 80px rgba(99,102,241,.3),inset 0 1px 0 rgba(129,140,248,.2)}

    .popular-badge{
      position:absolute;top:-14px;left:50%;transform:translateX(-50%);
      background:linear-gradient(135deg,#6366f1,#818cf8);color:#fff;
      font-size:11px;font-weight:700;padding:4px 18px;border-radius:20px;
      letter-spacing:.5px;white-space:nowrap;box-shadow:0 4px 16px rgba(99,102,241,.5)
    }

    .card-icon{font-size:34px;margin-bottom:18px}
    .card-name{font-size:20px;font-weight:800;margin-bottom:6px;letter-spacing:-.01em}
    .card-tagline{color:rgba(255,255,255,.4);font-size:13px;line-height:1.55;margin-bottom:22px}
    .price-row{margin-bottom:22px}
    .price-amount{font-size:46px;font-weight:900;letter-spacing:-.04em;line-height:1}
    .popular .price-amount{background:linear-gradient(135deg,#818cf8,#60a5fa);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
    .price-period{font-size:14px;color:rgba(255,255,255,.35);font-weight:400}
    .card-divider{height:1px;background:rgba(255,255,255,.06);margin-bottom:22px}

    .card-features{list-style:none;display:flex;flex-direction:column;gap:12px;margin-bottom:28px;flex:1}
    .card-features li{display:flex;align-items:flex-start;gap:10px;font-size:13.5px;color:rgba(255,255,255,.68);line-height:1.45}
    .feat-check{width:18px;height:18px;background:rgba(99,102,241,.18);border:1px solid rgba(99,102,241,.35);border-radius:5px;display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-top:1px}
    .popular .feat-check{background:rgba(99,102,241,.28);border-color:rgba(129,140,248,.55)}

    .card-btn{display:block;text-align:center;text-decoration:none;padding:14px;border-radius:12px;font-size:14px;font-weight:700;transition:all .2s;letter-spacing:.2px}
    .btn-outline{background:transparent;border:1px solid rgba(99,102,241,.35);color:rgba(255,255,255,.78)}
    .btn-outline:hover{background:rgba(99,102,241,.12);border-color:rgba(99,102,241,.6);color:#fff;transform:none}
    .btn-primary{background:linear-gradient(135deg,#6366f1,#818cf8);color:#fff;border:none;box-shadow:0 4px 20px rgba(99,102,241,.42)}
    .btn-primary:hover{box-shadow:0 6px 32px rgba(99,102,241,.65);transform:translateY(-1px)}
  </style>
</head>
<body>

<canvas id="network-canvas"></canvas>

<!-- ── HERO ── -->
<section class="hero">
  <div class="hero-content">
    <div class="hero-badge"><span class="dot-pulse"></span> Automatizaciones en vivo</div>
    <h1>La IA que trabaja<br><span>mientras tú descansas</span></h1>
    <p>Simula cada automatización en tiempo real. Ve exactamente cómo funciona antes de comprarlo.</p>
    <a href="#biblioteca" class="btn-hero">
      Probar Demos
      <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
    </a>
    <span class="scroll-hint">scroll para explorar</span>
  </div>
</section>

<!-- ── LIBRARY ── -->
<section class="library" id="biblioteca">
  <div class="library-inner">
    <div class="library-hdr">
      <h2>Elige tu automatización</h2>
      <p>5 demos interactivas — simulaciones reales de cada flujo de trabajo.</p>
    </div>

    <div class="pricing-grid">

      <!-- 1 · Leads -->
      <div class="pricing-card">
        <div class="card-icon">🎯</div>
        <div class="card-name">Calificación de Leads</div>
        <div class="card-tagline">Bot captura datos y califica prospectos automáticamente</div>
        <div class="price-row"><span class="price-amount">$3,000</span><span class="price-period">/mes</span></div>
        <div class="card-divider"></div>
        <ul class="card-features">
          <li><div class="feat-check"><svg width="10" height="8" viewBox="0 0 10 8" fill="none" stroke="#818cf8" stroke-width="2"><polyline points="1,4 4,7 9,1"/></svg></div>Bot con IA que hace las preguntas clave</li>
          <li><div class="feat-check"><svg width="10" height="8" viewBox="0 0 10 8" fill="none" stroke="#818cf8" stroke-width="2"><polyline points="1,4 4,7 9,1"/></svg></div>Calificación automática alta / media / baja</li>
          <li><div class="feat-check"><svg width="10" height="8" viewBox="0 0 10 8" fill="none" stroke="#818cf8" stroke-width="2"><polyline points="1,4 4,7 9,1"/></svg></div>Notificación instantánea por WhatsApp</li>
        </ul>
        <a href="/calificacion-de-leads" class="card-btn btn-outline">▶ Ver Demo en Vivo</a>
      </div>

      <!-- 2 · Pipeline (Popular) -->
      <div class="pricing-card popular">
        <div class="popular-badge">⭐ Popular</div>
        <div class="card-icon">🚀</div>
        <div class="card-name">Pipeline de Ventas</div>
        <div class="card-tagline">Sistema completo para gestionar cada etapa del proceso de ventas</div>
        <div class="price-row"><span class="price-amount">$7,500</span><span class="price-period">/mes</span></div>
        <div class="card-divider"></div>
        <ul class="card-features">
          <li><div class="feat-check"><svg width="10" height="8" viewBox="0 0 10 8" fill="none" stroke="#818cf8" stroke-width="2"><polyline points="1,4 4,7 9,1"/></svg></div>Pipeline automático con 5 etapas</li>
          <li><div class="feat-check"><svg width="10" height="8" viewBox="0 0 10 8" fill="none" stroke="#818cf8" stroke-width="2"><polyline points="1,4 4,7 9,1"/></svg></div>Mensajes automáticos en cada movimiento</li>
          <li><div class="feat-check"><svg width="10" height="8" viewBox="0 0 10 8" fill="none" stroke="#818cf8" stroke-width="2"><polyline points="1,4 4,7 9,1"/></svg></div>Secuencia de follow-up a 30 días</li>
        </ul>
        <a href="/pipeline-de-ventas" class="card-btn btn-primary">▶ Ver Demo en Vivo</a>
      </div>

      <!-- 3 · Nurturing -->
      <div class="pricing-card">
        <div class="card-icon">💬</div>
        <div class="card-name">Nurturing WhatsApp</div>
        <div class="card-tagline">Convierte conversaciones en ventas sin intervención manual</div>
        <div class="price-row"><span class="price-amount">$3,000</span><span class="price-period">/mes</span></div>
        <div class="card-divider"></div>
        <ul class="card-features">
          <li><div class="feat-check"><svg width="10" height="8" viewBox="0 0 10 8" fill="none" stroke="#818cf8" stroke-width="2"><polyline points="1,4 4,7 9,1"/></svg></div>Bot conversacional con IA (Llama 3.3)</li>
          <li><div class="feat-check"><svg width="10" height="8" viewBox="0 0 10 8" fill="none" stroke="#818cf8" stroke-width="2"><polyline points="1,4 4,7 9,1"/></svg></div>Detección automática de intención de compra</li>
          <li><div class="feat-check"><svg width="10" height="8" viewBox="0 0 10 8" fill="none" stroke="#818cf8" stroke-width="2"><polyline points="1,4 4,7 9,1"/></svg></div>Secuencia de reactivación si desaparece</li>
        </ul>
        <a href="/nurturing-whatsapp" class="card-btn btn-outline">▶ Ver Demo en Vivo</a>
      </div>

      <!-- 4 · Atención 24/7 -->
      <div class="pricing-card">
        <div class="card-icon">🌙</div>
        <div class="card-name">Atención 24/7</div>
        <div class="card-tagline">Bot que responde clientes a cualquier hora, sin costo humano</div>
        <div class="price-row"><span class="price-amount">$4,500</span><span class="price-period">/mes</span></div>
        <div class="card-divider"></div>
        <ul class="card-features">
          <li><div class="feat-check"><svg width="10" height="8" viewBox="0 0 10 8" fill="none" stroke="#818cf8" stroke-width="2"><polyline points="1,4 4,7 9,1"/></svg></div>Respuestas instantáneas las 24 horas, 7 días</li>
          <li><div class="feat-check"><svg width="10" height="8" viewBox="0 0 10 8" fill="none" stroke="#818cf8" stroke-width="2"><polyline points="1,4 4,7 9,1"/></svg></div>Resuelve preguntas, quejas y reservas solo</li>
          <li><div class="feat-check"><svg width="10" height="8" viewBox="0 0 10 8" fill="none" stroke="#818cf8" stroke-width="2"><polyline points="1,4 4,7 9,1"/></svg></div>Escala a humano solo cuando es necesario</li>
        </ul>
        <a href="/atencion-24-7" class="card-btn btn-outline">▶ Ver Demo en Vivo</a>
      </div>

      <!-- 5 · Report -->
      <div class="pricing-card">
        <div class="card-icon">📊</div>
        <div class="card-name">Reporte Semanal</div>
        <div class="card-tagline">Reportes ejecutivos automáticos para clientes cada semana</div>
        <div class="price-row"><span class="price-amount">$1,000</span><span class="price-period">/mes</span></div>
        <div class="card-divider"></div>
        <ul class="card-features">
          <li><div class="feat-check"><svg width="10" height="8" viewBox="0 0 10 8" fill="none" stroke="#818cf8" stroke-width="2"><polyline points="1,4 4,7 9,1"/></svg></div>Recopila datos de WhatsApp, CRM, Ads y más</li>
          <li><div class="feat-check"><svg width="10" height="8" viewBox="0 0 10 8" fill="none" stroke="#818cf8" stroke-width="2"><polyline points="1,4 4,7 9,1"/></svg></div>Análisis ejecutivo generado por IA</li>
          <li><div class="feat-check"><svg width="10" height="8" viewBox="0 0 10 8" fill="none" stroke="#818cf8" stroke-width="2"><polyline points="1,4 4,7 9,1"/></svg></div>Enviado automáticamente al cliente cada lunes</li>
        </ul>
        <a href="/reporte-semanal" class="card-btn btn-outline">▶ Ver Demo en Vivo</a>
      </div>

    </div>
  </div>
</section>

<script>
(function(){
  const c=document.getElementById('network-canvas'),ctx=c.getContext('2d');
  let W,H,nodes=[];
  const N=70,DIST=180,SPD=0.4;
  function resize(){W=c.width=innerWidth;H=c.height=innerHeight}
  function init(){nodes=[];for(let i=0;i<N;i++)nodes.push({x:Math.random()*W,y:Math.random()*H,vx:(Math.random()-.5)*SPD,vy:(Math.random()-.5)*SPD,r:Math.random()*2+1.2,o:Math.random()*.5+.4})}
  function draw(){
    ctx.clearRect(0,0,W,H);
    for(let i=0;i<nodes.length;i++)for(let j=i+1;j<nodes.length;j++){
      const dx=nodes[j].x-nodes[i].x,dy=nodes[j].y-nodes[i].y,d=Math.sqrt(dx*dx+dy*dy);
      if(d<DIST){const a=(1-d/DIST)*.35;const g=ctx.createLinearGradient(nodes[i].x,nodes[i].y,nodes[j].x,nodes[j].y);g.addColorStop(0,`rgba(99,102,241,${a})`);g.addColorStop(1,`rgba(96,165,250,${a})`);ctx.beginPath();ctx.moveTo(nodes[i].x,nodes[i].y);ctx.lineTo(nodes[j].x,nodes[j].y);ctx.strokeStyle=g;ctx.lineWidth=.8;ctx.stroke()}
    }
    nodes.forEach(n=>{const g=ctx.createRadialGradient(n.x,n.y,0,n.x,n.y,n.r*8);g.addColorStop(0,`rgba(99,102,241,${n.o*.6})`);g.addColorStop(1,'rgba(99,102,241,0)');ctx.beginPath();ctx.arc(n.x,n.y,n.r*8,0,Math.PI*2);ctx.fillStyle=g;ctx.fill();ctx.beginPath();ctx.arc(n.x,n.y,n.r,0,Math.PI*2);ctx.fillStyle=`rgba(180,190,255,${n.o})`;ctx.fill()});
  }
  function update(){nodes.forEach(n=>{n.x+=n.vx;n.y+=n.vy;if(n.x<0||n.x>W)n.vx*=-1;if(n.y<0||n.y>H)n.vy*=-1})}
  function loop(){update();draw();requestAnimationFrame(loop)}
  window.addEventListener('scroll',()=>{const max=document.body.scrollHeight-innerHeight;c.style.opacity=max>0?Math.max(0.2,1-scrollY/max*0.8):1});
  addEventListener('resize',()=>{resize();init()});
  resize();init();loop();
})();
document.querySelector('.btn-hero').addEventListener('click',e=>{e.preventDefault();document.getElementById('biblioteca').scrollIntoView({behavior:'smooth'})});
</script>
</body>
</html>
