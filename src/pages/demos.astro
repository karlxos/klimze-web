  .roi-card-highlight{
    background:rgba(99,102,241,.14);
    box-shadow:0 0 50px rgba(99,102,241,.18),0 8px 40px rgba(0,0,0,.4),inset 0 1px 0 rgba(129,140,248,.12)
  }

  .roi-icon{font-size:28px;margin-bottom:10px}
  .roi-name{font-size:16px;font-weight:800;margin-bottom:20px;letter-spacing:-.01em}

  .roi-comparison{display:flex;align-items:center;gap:12px;margin-bottom:16px}
  .roi-col{flex:1;background:rgba(0,0,0,.25);border-radius:12px;padding:14px 12px;text-align:center}
  .roi-col-label{font-size:10px;font-weight:600;letter-spacing:.8px;text-transform:uppercase;color:rgba(255,255,255,.3);margin-bottom:8px}
  .roi-employees{font-size:11px;color:rgba(255,255,255,.45);line-height:1.5;margin-bottom:10px}
  .roi-employees span{display:block;color:rgba(255,255,255,.28);font-size:10px}

  .roi-cost-bad{font-size:28px;font-weight:900;color:#f87171;letter-spacing:-.03em}
  .roi-cost-bad span{font-size:13px;font-weight:400;opacity:.7}
  .roi-cost-good{font-size:28px;font-weight:900;color:#34d399;letter-spacing:-.03em}
  .roi-cost-good span{font-size:13px;font-weight:400;opacity:.7}
  .roi-retainer{font-size:11px;color:rgba(255,255,255,.45);margin-bottom:10px}

  .roi-arrow{font-size:18px;color:rgba(255,255,255,.2);flex-shrink:0}

  .roi-saving{background:rgba(52,211,153,.07);border:1px solid rgba(52,211,153,.15);border-radius:10px;padding:10px 14px;font-size:12px;color:rgba(255,255,255,.5);text-align:center}
  .roi-saving strong{color:#34d399;font-weight:700}

  .roi-cta{text-align:center}
  .roi-cta-text{font-size:20px;font-weight:700;line-height:1.5;margin-bottom:28px;color:rgba(255,255,255,.75)}
  .roi-cta-btn{display:inline-block;background:linear-gradient(135deg,#6366f1,#818cf8);color:#fff;text-decoration:none;padding:16px 48px;border-radius:14px;font-size:16px;font-weight:700;box-shadow:0 0 50px rgba(99,102,241,.4),0 8px 32px rgba(0,0,0,.4);transition:all .2s}
  .roi-cta-btn:hover{box-shadow:0 0 70px rgba(99,102,241,.6),0 12px 40px rgba(0,0,0,.5);transform:translateY(-2px)}

  @media(max-width:768px){
    .roi-card{flex:0 0 100%;max-width:100%}
    .roi-comparison{flex-direction:column}
    .roi-arrow{transform:rotate(90deg)}
  }
</style>

<script>
(function(){
  const c=document.getElementById('network-canvas'),ctx=c.getContext('2d');
  let W,H,nodes=[];
  const N=70,DIST=180,SPD=0.4;
  function resize(){W=c.width=innerWidth;H=c.height=innerHeight}
  function init(){nodes=[];for(let i=0;i<N;i++)nodes.push({x:Math.random()*W,y:Math.random()*H,vx:(Math.random()-.5)*SPD,vy:(Math.random()-.5)*SPD,r:Math.random()*2+1.2,o:Math.random()*.5+.4})}
  function draw(){
    ctx.clearRect(0,0,W,H);
    for(let i=0;i<nodes.length;i++)for(let j=i+1;j<nodes.length;j++){
      const dx=nodes[j].x-nodes[i].x,dy=nodes[j].y-nodes[i].y,d=Math.sqrt(dx*dx+dy*dy);
      if(d<DIST){const a=(1-d/DIST)*.35;const g=ctx.createLinearGradient(nodes[i].x,nodes[i].y,nodes[j].x,nodes[j].y);g.addColorStop(0,`rgba(99,102,241,${a})`);g.addColorStop(1,`rgba(96,165,250,${a})`);ctx.beginPath();ctx.moveTo(nodes[i].x,nodes[i].y);ctx.lineTo(nodes[j].x,nodes[j].y);ctx.strokeStyle=g;ctx.lineWidth=.8;ctx.stroke()}
    }
    nodes.forEach(n=>{const g=ctx.createRadialGradient(n.x,n.y,0,n.x,n.y,n.r*8);g.addColorStop(0,`rgba(99,102,241,${n.o*.6})`);g.addColorStop(1,'rgba(99,102,241,0)');ctx.beginPath();ctx.arc(n.x,n.y,n.r*8,0,Math.PI*2);ctx.fillStyle=g;ctx.fill();ctx.beginPath();ctx.arc(n.x,n.y,n.r,0,Math.PI*2);ctx.fillStyle=`rgba(180,190,255,${n.o})`;ctx.fill()});
  }
  function update(){nodes.forEach(n=>{n.x+=n.vx;n.y+=n.vy;if(n.x<0||n.x>W)n.vx*=-1;if(n.y<0||n.y>H)n.vy*=-1})}
  function loop(){update();draw();requestAnimationFrame(loop)}
  window.addEventListener('scroll',()=>{const max=document.body.scrollHeight-innerHeight;c.style.opacity=max>0?Math.max(0.2,1-scrollY/max*0.8):1});
  addEventListener('resize',()=>{resize();init()});
  resize();init();loop();
})();
document.querySelector('.btn-hero').addEventListener('click',e=>{e.preventDefault();document.getElementById('biblioteca').scrollIntoView({behavior:'smooth'})});
</script>
</body>
</html>
