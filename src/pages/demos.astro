      <!-- 4. Generación de Contenido -->
      <div class="demo-card">
        <div class="card-header">
          <div class="card-icon">✍️</div>
          <div class="card-meta">
            <div class="card-title">Generación de Contenido</div>
            <div class="card-desc">Post listo para publicar en redes sociales, optimizado por IA.</div>
          </div>
          <div class="card-price">$3,000</div>
        </div>
        <div class="card-body">
          <label>Negocio / Nicho</label>
          <input type="text" id="cont-negocio" placeholder="Ej: Clínica dental" />
          <label>Red social</label>
          <select id="cont-red">
            <option value="Instagram">Instagram</option>
            <option value="Facebook">Facebook</option>
            <option value="LinkedIn">LinkedIn</option>
            <option value="TikTok">TikTok</option>
          </select>
          <label>Tema o producto a destacar</label>
          <input type="text" id="cont-tema" placeholder="Ej: Blanqueamiento dental express en 1 hora" />
          <button class="btn-run" id="cont-btn" onclick="runContenido()">Generar post →</button>
          <div class="spinner-text" id="cont-spinner">Escribiendo post...</div>
          <div class="result-box" id="cont-result">
            <div class="result-label">Post generado</div>
            <div id="cont-text"></div>
          </div>
        </div>
