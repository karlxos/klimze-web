          <input type="text" id="nurt-negocio" placeholder="Ej: Spa de belleza" />
          <label>Mensaje del cliente (tú eres el cliente)</label>
          <textarea id="nurt-mensaje" placeholder="Ej: Hola buenas, cuánto cuesta el masaje relajante y tienen disponibilidad este sábado?" style="height:75px;"></textarea>
          <button class="btn-run" id="nurt-btn" onclick="runNurturing()">Ver respuesta del bot →</button>
          <div class="spinner-text" id="nurt-spinner">Generando respuesta...</div>
          <div class="result-box" id="nurt-result">
            <div class="result-label">Bot responde</div>
