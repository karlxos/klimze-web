      <!-- 5. Reporte Semanal -->
      <div class="demo-card">
        <div class="card-header">
          <div class="card-icon">📊</div>
          <div class="card-meta">
            <div class="card-title">Reporte Semanal</div>
            <div class="card-desc">Ingresa métricas crudas y la IA genera el resumen ejecutivo.</div>
          </div>
          <div class="card-price">$1,000</div>
        </div>
        <div class="card-body">
          <label>Nombre del cliente / negocio</label>
          <input type="text" id="rep-cliente" placeholder="Ej: Farmacia San José" />
          <label>Métricas de la semana (texto libre)</label>
          <textarea id="rep-metricas" placeholder="Ej: 142 mensajes recibidos, 38 citas agendadas, 12 clientes no llegaron, 6 reseñas nuevas en Google, ventas $4,200..." style="height:85px;"></textarea>
          <button class="btn-run" id="rep-btn" onclick="runReporte()">Generar reporte →</button>
          <div class="spinner-text" id="rep-spinner">Elaborando reporte...</div>
          <div class="result-box" id="rep-result">
            <div class="result-label">Reporte ejecutivo</div>
            <div id="rep-text"></div>
          </div>
        </div>
      </div>

    </div>
