<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Calificación de Leads — Demo Klimze</title>
  <link rel="stylesheet" href="/demo.css" />
</head>
<body>

<!-- NAV -->
<nav class="demo-nav">
  <a href="/demos" class="back-link">
    <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
    Demos
  </a>
  <div class="nav-demo-name">🎯 Calificación de Leads</div>
  <div class="nav-price">$3,000/mes</div>
</nav>

<!-- HEADER -->
<header class="demo-header">
  <canvas id="mini-canvas"></canvas>
  <div class="demo-header-content">
    <div class="demo-header-icon">🎯</div>
    <h1>Calificación de <span>Leads</span></h1>
    <p>El bot hace las preguntas clave, la IA califica la prioridad y te avisa por WhatsApp — sin intervención humana.</p>
    <button class="btn-start-main" id="start-btn" onclick="initDemo()">
      ▶ Iniciar simulación
    </button>
  </div>
</header>

<!-- DEMO AREA -->
<div class="demo-container">
  <div id="demo-area" style="display:none">
    <div class="steps-bar">
      <div class="step-item current" id="step-1">1. Chat del bot</div>
      <div class="step-item" id="step-2">2. Análisis IA</div>
      <div class="step-item" id="step-3">3. Notificación</div>
    </div>

    <!-- Phase 1: Chat -->
    <div class="phase active" id="phase-1">
      <div class="chat-window">
        <div class="chat-header">
          <div class="chat-avatar">🤖</div>
          <div>
            <div class="chat-bot-name">Asistente Klimze</div>
            <div class="chat-bot-status"><span class="online-dot"></span>En línea</div>
          </div>
        </div>
        <div class="chat-messages" id="msgs"></div>
        <div class="chat-input-row">
          <input class="chat-input" id="chat-input" placeholder="Escribe tu respuesta..." onkeydown="if(event.key==='Enter')sendMsg()" />
          <button class="chat-send" id="chat-send" onclick="sendMsg()">
            <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="white" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M22 2L11 13M22 2l-7 20-4-9-9-4 20-7z"/></svg>
          </button>
        </div>
      </div>
    </div>

    <!-- Phase 2: Analysis -->
    <div class="phase" id="phase-2">
      <div class="analysis-wrap">
        <div class="analysis-ring"></div>
        <div class="analysis-label">Analizando prospecto con IA...</div>
        <div class="analysis-steps">
          <div class="astep" id="as-1"><div class="astep-dot"></div>Procesando información del lead</div>
          <div class="astep" id="as-2"><div class="astep-dot"></div>Evaluando intención de compra</div>
          <div class="astep" id="as-3"><div class="astep-dot"></div>Calculando score de prioridad</div>
          <div class="astep" id="as-4"><div class="astep-dot"></div>Generando respuesta personalizada</div>
        </div>
      </div>
    </div>

    <!-- Phase 3: Notification -->
    <div class="phase" id="phase-3">
      <div class="notif-wrap">
        <div class="notif-label">📱 Notificación recibida por la empresa</div>
        <div class="notif-phone">
          <div class="notif-phone-bar">
            <div class="notif-app-icon">💬</div>
            <div class="notif-app-name">WhatsApp Business</div>
            <div class="notif-time" id="notif-time">Ahora</div>
          </div>
          <div class="notif-body" id="notif-body"></div>
        </div>
        <button class="reset-btn" onclick="resetDemo()">↺ Reiniciar simulación</button>
      </div>
    </div>
  </div>
</div>

<script>
// ── Mini canvas ──────────────────────────────────────
(function(){
  const c=document.getElementById('mini-canvas'),ctx=c.getContext('2d');
  let W,H,nodes=[];
  const N=40,DIST=140,SPD=0.35;
  function resize(){W=c.width=c.offsetWidth;H=c.height=c.offsetHeight}
  function init(){nodes=[];for(let i=0;i<N;i++)nodes.push({x:Math.random()*W,y:Math.random()*H,vx:(Math.random()-.5)*SPD,vy:(Math.random()-.5)*SPD,r:Math.random()*1.5+1,o:Math.random()*.4+.3})}
  function draw(){
    ctx.clearRect(0,0,W,H);
    for(let i=0;i<nodes.length;i++)for(let j=i+1;j<nodes.length;j++){
      const dx=nodes[j].x-nodes[i].x,dy=nodes[j].y-nodes[i].y,d=Math.sqrt(dx*dx+dy*dy);
      if(d<DIST){const a=(1-d/DIST)*.28;ctx.beginPath();ctx.moveTo(nodes[i].x,nodes[i].y);ctx.lineTo(nodes[j].x,nodes[j].y);ctx.strokeStyle=`rgba(99,102,241,${a})`;ctx.lineWidth=.7;ctx.stroke()}
    }
    nodes.forEach(n=>{ctx.beginPath();ctx.arc(n.x,n.y,n.r,0,Math.PI*2);ctx.fillStyle=`rgba(180,190,255,${n.o})`;ctx.fill()});
  }
  function update(){nodes.forEach(n=>{n.x+=n.vx;n.y+=n.vy;if(n.x<0||n.x>W)n.vx*=-1;if(n.y<0||n.y>H)n.vy*=-1})}
  function loop(){update();draw();requestAnimationFrame(loop)}
  new ResizeObserver(()=>{resize();init()}).observe(c.parentElement);
  resize();init();loop();
})();

// ── Groq proxy ──────────────────────────────────────
async function groq(prompt,temp=0.7){
  const r=await fetch('/api/groq',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({model:'llama-3.3-70b-versatile',messages:[{role:'user',content:prompt}],temperature:temp})});
  const d=await r.json();
  return d.choices[0].message.content;
}

// ── Helpers ──────────────────────────────────────────
function sleep(ms){return new Promise(r=>setTimeout(r,ms))}
function setPhase(n){
  document.querySelectorAll('.phase').forEach((p,i)=>p.classList.toggle('active',i===n-1));
  document.querySelectorAll('.step-item').forEach((s,i)=>{
    s.className='step-item'+(i<n-1?' done':i===n-1?' current':'');
  });
}
async function animateSteps(ids,delay=650){
  for(const id of ids){
    await sleep(delay);
    const el=document.getElementById(id);
    if(!el)continue;
    el.classList.add('active');
    await sleep(delay);
    el.classList.add('done');el.classList.remove('active');
  }
}

// ── State ────────────────────────────────────────────
const SCRIPT=[
  '¡Hola! 👋 Soy el asistente virtual de Klimze. ¿Con quién tengo el gusto?',
  n=>`¡Mucho gusto, ${n}! 😊 ¿A qué se dedica tu negocio o empresa?`,
  ()=>'¿Qué es lo que más quieres mejorar actualmente?\n\n🔹 Conseguir más clientes\n🔹 Automatizar procesos\n🔹 Ambos',
  ()=>'¿Tienes algún presupuesto mensual en mente? (puede ser un rango)',
  ()=>'Última pregunta: ¿cuándo te gustaría empezar?',
  ()=>'Gracias por la información. Dame un momento, voy a revisar tu perfil... ⏳',
];
const FIELDS=[null,'nombre','negocio','objetivo','presupuesto','urgencia'];
let state={step:0,data:{}};

// ── Init ─────────────────────────────────────────────
function initDemo(){
  document.getElementById('start-btn').style.display='none';
  document.getElementById('demo-area').style.display='block';
  document.getElementById('demo-area').scrollIntoView({behavior:'smooth',block:'start'});
  state={step:0,data:{}};
  setPhase(1);
  setTimeout(()=>botMsg(SCRIPT[0]),700);
}
function resetDemo(){
  document.getElementById('start-btn').style.display='';
  document.getElementById('demo-area').style.display='none';
  document.getElementById('msgs').innerHTML='';
  document.getElementById('notif-body').innerHTML='';
  document.getElementById('chat-input').disabled=false;
  document.getElementById('chat-input').value='';
  document.getElementById('chat-send').disabled=false;
  window.scrollTo({top:0,behavior:'smooth'});
}

// ── Chat ─────────────────────────────────────────────
function botMsg(text){
  const msgs=document.getElementById('msgs');
  const t=document.createElement('div');t.className='typing';t.innerHTML='<span></span><span></span><span></span>';
  msgs.appendChild(t);msgs.scrollTop=msgs.scrollHeight;
  return new Promise(res=>setTimeout(()=>{
    t.remove();
    const m=document.createElement('div');m.className='msg bot';m.textContent=text;
    msgs.appendChild(m);msgs.scrollTop=msgs.scrollHeight;res();
  },1300));
}
function userMsg(text){
  const msgs=document.getElementById('msgs');
  const m=document.createElement('div');m.className='msg user';m.textContent=text;
  msgs.appendChild(m);msgs.scrollTop=msgs.scrollHeight;
}

async function sendMsg(){
  const inp=document.getElementById('chat-input');
  const val=inp.value.trim();if(!val)return;
  inp.value='';
  userMsg(val);
  state.step++;
  if(FIELDS[state.step])state.data[FIELDS[state.step]]=val;
  if(state.step>=5){
    inp.disabled=true;document.getElementById('chat-send').disabled=true;
    const last=SCRIPT[5];
    await botMsg(typeof last==='function'?last():last);
    await sleep(1200);
    setPhase(2);
    await runAnalysis();
    return;
  }
  const next=SCRIPT[state.step];
  await botMsg(typeof next==='function'?next(val):next);
  inp.focus();
}

// ── Analysis ─────────────────────────────────────────
async function runAnalysis(){
  animateSteps(['as-1','as-2','as-3','as-4'],650);
  const {nombre,negocio,objetivo,presupuesto,urgencia}=state.data;
  const prompt=`Eres un calificador de leads para una agencia de automatizaciones en Panamá. Analiza y responde SOLO JSON sin markdown:
{"calificado":true,"prioridad":"alta","razon":"string corto en español","respuesta":"mensaje personalizado en español max 2 líneas"}
Datos: nombre=${nombre||'?'}, negocio=${negocio||'?'}, objetivo=${objetivo||'?'}, presupuesto=${presupuesto||'?'}, urgencia=${urgencia||'?'}`;
  const raw=await groq(prompt,.3);
  let cal;
  try{cal=JSON.parse(raw.replace(/```(?:json)?\n?/g,'').replace(/```/g,'').trim())}
  catch{cal={calificado:true,prioridad:'alta',razon:'Lead con buena intención de compra',respuesta:`Hola ${nombre||''}! Tenemos exactamente lo que necesitas. ¿Podemos agendar una llamada esta semana?`}}
  await sleep(2800);
  buildNotification(cal);
  setPhase(3);
}

function buildNotification(cal){
  const {nombre,negocio,objetivo,presupuesto,urgencia}=state.data;
  const prioColor=cal.prioridad==='alta'?'#ff6b6b':cal.prioridad==='media'?'#ffb84d':'#888';
  const icon=cal.calificado?'✅':'⚠️';
  const title=cal.calificado?'🔔 NUEVO LEAD CALIFICADO':'⚠️ LEAD BAJO POTENCIAL';
  const now=new Date();
  document.getElementById('notif-time').textContent=now.getHours()+':'+String(now.getMinutes()).padStart(2,'0');
  document.getElementById('notif-body').innerHTML=`
    <div class="notif-title">${title}</div>
    <div class="notif-line"><strong>👤</strong>${nombre||'—'}</div>
    <div class="notif-line"><strong>🏪</strong>${negocio||'—'}</div>
    <div class="notif-line"><strong>🎯</strong>${objetivo||'—'}</div>
    <div class="notif-line"><strong>💰</strong>${presupuesto||'—'}</div>
    <div class="notif-line"><strong>⚡</strong>${urgencia||'—'}</div>
    <div class="notif-divider"></div>
    <div class="notif-line">${icon} <strong style="color:${prioColor}">Prioridad ${(cal.prioridad||'').toUpperCase()}</strong></div>
    <div class="notif-line" style="font-size:11.5px;color:rgba(255,255,255,.4);margin-top:1px">${cal.razon||''}</div>
    <div class="notif-divider"></div>
    <div class="notif-suggestion">
      <div class="notif-suggestion-label">💬 Respuesta sugerida</div>
      ${cal.respuesta||''}
    </div>`;
}
</script>
</body>
</html>
