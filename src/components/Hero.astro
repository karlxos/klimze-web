---
---

<section class="relative min-h-screen flex items-center justify-center overflow-hidden bg-primary pt-20">
  <!-- Background glow -->
  <div
    class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] rounded-full pointer-events-none"
    style="background: radial-gradient(ellipse at center, rgba(147,225,216,0.12) 0%, transparent 70%);"
  ></div>

  <div class="relative z-10 max-w-5xl mx-auto px-6 text-center pb-20">
    <!-- Tag -->
    <div class="inline-flex items-center gap-2 bg-tertiary/10 border border-tertiary/30 rounded-full px-4 py-1.5 mb-8 animate-fade-in" aria-label="Chatbot WhatsApp para clínicas disponible 24/7">
      <span class="w-2 h-2 rounded-full bg-tertiary animate-pulse" aria-hidden="true"></span>
      <span class="text-tertiary text-sm font-medium">Automatización de citas para clínicas — disponible 24/7</span>
    </div>

    <!-- H1 — incluye keyword primaria + pain point -->
    <h1
      class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-black text-secondary leading-tight mb-6 opacity-0 animate-fade-up"
      style="animation-delay: 0.15s; animation-fill-mode: forwards;"
    >
      Automatiza las citas de<br />
      tu clínica por WhatsApp.<br />
      <span class="text-tertiary">¿Cuánto pierdes sin esto?</span>
    </h1>

    <!-- Subheadline — refuerza keywords secundarias -->
    <p
      class="text-secondary/60 text-lg md:text-xl max-w-2xl mx-auto mb-10 opacity-0 animate-fade-up"
      style="animation-delay: 0.3s; animation-fill-mode: forwards;"
    >
      klimze. es el chatbot para clínicas que agenda, confirma y reactiva pacientes
      automáticamente — sin llamadas, sin recepcionista, sin citas perdidas. Usado por
      clínicas en Panamá y toda Latinoamérica.
    </p>

    <!-- CTAs -->
    <div
      class="flex flex-col sm:flex-row items-center justify-center gap-4 opacity-0 animate-fade-up"
      style="animation-delay: 0.45s; animation-fill-mode: forwards;"
    >
      <a
        href="#calculadora"
        aria-label="Calcular cuánto dinero pierde tu clínica por citas perdidas"
        class="bg-tertiary text-primary font-bold px-8 py-4 rounded-full text-base hover:bg-tertiary/90 hover:scale-105 transition-all duration-200 shadow-lg shadow-tertiary/20"
      >
        Calcular cuánto pierdo →
      </a>
      <a
        href="#funcionalidades"
        aria-label="Ver todas las funcionalidades de klimze. para automatización de clínicas"
        class="border border-secondary/20 text-secondary font-semibold px-8 py-4 rounded-full text-base hover:border-tertiary hover:text-tertiary transition-all duration-200"
      >
        Ver funcionalidades
      </a>
    </div>

    <!-- Stats — outcome-focused -->
    <div
      class="mt-16 grid grid-cols-3 gap-6 max-w-lg mx-auto opacity-0 animate-fade-up"
      style="animation-delay: 0.6s; animation-fill-mode: forwards;"
    >
      <div class="text-center">
        <div class="text-2xl font-black text-tertiary" aria-label="Reducción del 70% en citas perdidas">−70%</div>
        <div class="text-secondary/50 text-xs mt-1">Citas perdidas</div>
      </div>
      <div class="border-x border-secondary/10 text-center">
        <div class="text-2xl font-black text-tertiary" aria-label="Atención automática 24 horas los 7 días">24/7</div>
        <div class="text-secondary/50 text-xs mt-1">Atención automática</div>
      </div>
      <div class="text-center">
        <div class="text-2xl font-black text-tertiary" aria-label="Promedio de $4,200 recuperados por mes">$4,200</div>
        <div class="text-secondary/50 text-xs mt-1">Recuperados/mes avg.</div>
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 opacity-40">
    <span class="text-secondary text-xs">Descubre cuánto pierdes</span>
    <div class="w-px h-8 bg-secondary/30 relative overflow-hidden">
      <div class="absolute top-0 left-0 w-full h-1/2 bg-tertiary animate-bounce"></div>
    </div>
  </div>
</section>
