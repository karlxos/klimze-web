---
---

<footer class="bg-[#080808] border-t border-secondary/5 py-12" itemscope itemtype="https://schema.org/WPFooter">
  <div class="max-w-7xl mx-auto px-6">
    <div class="flex flex-col md:flex-row items-center justify-between gap-6">
      <!-- Brand -->
      <div class="flex flex-col items-center md:items-start gap-2" itemscope itemtype="https://schema.org/Organization">
        <a href="/" class="text-2xl font-black text-tertiary tracking-tight" itemprop="name" aria-label="klimze. — Inicio">klimze.</a>
        <p class="text-secondary/30 text-sm" itemprop="description">Automatización de citas médicas por WhatsApp para clínicas en Panamá y LATAM</p>
        <p class="text-secondary/20 text-xs">
          <span itemprop="addressCountry">Panamá</span> · <span itemprop="areaServed">Latinoamérica</span>
        </p>
      </div>

      <!-- Nav links -->
      <nav aria-label="Navegación del pie de página" class="flex flex-wrap items-center justify-center gap-6 text-sm text-secondary/40">
        <a href="#calculadora" class="hover:text-tertiary transition-colors">Calculadora de pérdidas</a>
        <a href="#funcionalidades" class="hover:text-tertiary transition-colors">Funcionalidades</a>
        <a href="#como-funciona" class="hover:text-tertiary transition-colors">Cómo funciona</a>
        <a href="#precios" class="hover:text-tertiary transition-colors">Precios</a>
        <a href="#faq" class="hover:text-tertiary transition-colors">FAQ</a>
        <a href="#contacto" class="hover:text-tertiary transition-colors">Contacto</a>
        <span class="text-secondary/10" aria-hidden="true">|</span>
        <a href="/privacidad" class="hover:text-tertiary transition-colors">Privacidad</a>
        <a href="/terminos" class="hover:text-tertiary transition-colors">Términos</a>
      </nav>
    </div>

    <!-- Divider -->
    <div class="border-t border-secondary/5 mt-8 pt-6 text-center">
      <p class="text-secondary/20 text-xs">
        &copy; <span id="footer-year">2025</span> klimze. Todos los derechos reservados. · Sistema de automatización de citas para clínicas médicas.
      </p>
    </div>
  </div>
</footer>

<script>
  const yearEl = document.getElementById('footer-year');
  if (yearEl) yearEl.textContent = String(new Date().getFullYear());
</script>
