---
const steps = [
  {
    number: '01',
    title: 'Tu cliente escribe por WhatsApp',
    desc: 'A cualquier hora, desde cualquier lugar. El chatbot de klimze. responde en segundos con una conversación natural e inteligente.',
    highlight: 'Tiempo de respuesta: 0 segundos',
  },
  {
    number: '02',
    title: 'El sistema agenda la cita automáticamente',
    desc: 'Entiende la intención del cliente, pregunta por el servicio y horario, verifica disponibilidad en tiempo real y confirma la reserva.',
    highlight: 'Sin que tú hagas nada',
  },
  {
    number: '03',
    title: 'La clínica crece sola',
    desc: 'Recordatorios automáticos, reactivación de inactivos, reseñas y seguimiento post-servicio, todo funcionando en piloto automático.',
    highlight: 'Más ingresos, menos trabajo',
  },
];
---

<section id="como-funciona" class="py-24 bg-secondary relative overflow-hidden">
  <!-- Decorative elements -->
  <div
    class="absolute top-0 right-0 w-96 h-96 rounded-full pointer-events-none opacity-30"
    style="background: radial-gradient(ellipse at top right, rgba(147,225,216,0.3), transparent 70%);"
  ></div>

  <div class="max-w-7xl mx-auto px-6">
    <!-- Header -->
    <div class="text-center mb-16" data-animate>
      <span class="text-primary/40 text-sm font-semibold tracking-widest uppercase">Cómo funciona klimze.</span>
      <h2 class="text-3xl sm:text-4xl md:text-5xl font-black text-primary mt-3 mb-4">
        De mensaje de WhatsApp a cita confirmada, automático
      </h2>
      <p class="text-primary/50 text-lg max-w-xl mx-auto">
        Tres pasos. Cero intervención manual. Tu sistema de gestión de citas médicas funcionando desde el primer día.
      </p>
    </div>

    <!-- Steps -->
    <div class="relative">
      <!-- Connector line (desktop) -->
      <div class="hidden lg:block absolute top-12 left-0 right-0 h-px bg-primary/10 mx-32" style="z-index:0;"></div>

      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 lg:gap-12 relative z-10">
        {steps.map((step, i) => (
          <div data-animate data-animate-delay={i * 120} class="relative flex flex-col items-center lg:items-start text-center lg:text-left">
            <!-- Number bubble -->
            <div class="flex items-center justify-center w-24 h-24 rounded-full bg-primary text-tertiary font-black text-3xl mb-6 shadow-xl flex-shrink-0 border-4 border-secondary">
              {step.number}
            </div>

            <!-- Connector arrow (mobile) -->
            {i < steps.length - 1 && (
              <div class="lg:hidden text-primary/20 text-3xl mb-6 select-none">↓</div>
            )}

            <h3 class="text-primary font-bold text-xl mb-3">{step.title}</h3>
            <p class="text-primary/60 text-sm leading-relaxed mb-4">{step.desc}</p>

            <!-- Highlight pill -->
            <span class="inline-block bg-primary/10 border border-primary/20 text-primary text-xs font-semibold px-3 py-1.5 rounded-full">
              {step.highlight}
            </span>
          </div>
        ))}
      </div>
    </div>

    <!-- Bottom CTA -->
    <div class="mt-16 text-center" data-animate data-animate-delay="200">
      <a
        href="#contacto"
        class="inline-flex items-center gap-2 bg-primary text-tertiary font-bold px-8 py-4 rounded-full hover:bg-primary/90 hover:scale-105 transition-all duration-200 shadow-lg"
      >
        Empieza hoy con klimze.
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
        </svg>
      </a>
    </div>
  </div>
</section>
