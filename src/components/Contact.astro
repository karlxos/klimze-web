---
---

<section id="contacto" class="py-24 bg-primary relative overflow-hidden">
<div class="max-w-7xl mx-auto px-6 relative z-10">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
      <!-- Left: copy -->
      <div data-animate>
        <span class="text-tertiary text-sm font-semibold tracking-widest uppercase">Demo gratuita — sin tarjeta de crédito</span>
        <h2 class="text-3xl sm:text-4xl md:text-5xl font-black text-secondary mt-3 mb-6">
          Automatiza tu clínica<br />en 24 horas
        </h2>
        <p class="text-secondary/50 text-lg mb-8 leading-relaxed">
          Agenda una demo de 30 minutos y te mostramos cómo klimze. automatiza la gestión
          de citas de tu clínica por WhatsApp desde el primer día — sin cambiar tus procesos.
        </p>

        <ul class="flex flex-col gap-4">
          {[
            'Demo personalizada a tu tipo de clínica',
            'Configuración inicial incluida',
            '30 días de prueba gratuita sin tarjeta',
            'Soporte de onboarding incluido',
            'Si en 30 días no bajan los pacientes que faltan a sus citas, cancelamos sin preguntas',
          ].map((item) => (
            <li class="flex items-center gap-3 text-secondary/70 text-sm">
              <span class="w-5 h-5 rounded-full bg-tertiary/20 border border-tertiary/40 flex items-center justify-center flex-shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-3 h-3 text-tertiary">
                  <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                </svg>
              </span>
              {item}
            </li>
          ))}
        </ul>
      </div>

      <!-- Right: form -->
      <div data-animate data-animate-delay="150" class="bg-secondary rounded-3xl p-8 md:p-10 shadow-2xl shadow-black/30">
        <h3 class="text-primary font-bold text-xl mb-6">Solicita tu demo gratuita</h3>

        <form
          id="demo-form"
          class="flex flex-col gap-4"
        >

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div class="flex flex-col gap-1.5">
              <label for="nombre" class="text-primary/70 text-xs font-semibold uppercase tracking-wide">
                Nombre
              </label>
              <input
                type="text"
                id="nombre"
                name="nombre"
                required
                placeholder="Tu nombre"
                class="bg-primary/5 border border-primary/15 rounded-xl px-4 py-3 text-primary text-sm placeholder:text-primary/30 focus:outline-none focus:border-primary/40 focus:ring-2 focus:ring-primary/10 transition-all"
              />
            </div>

            <div class="flex flex-col gap-1.5">
              <label for="clinica" class="text-primary/70 text-xs font-semibold uppercase tracking-wide">
                Nombre de la clínica
              </label>
              <input
                type="text"
                id="clinica"
                name="clinica"
                required
                placeholder="Clínica Ejemplo"
                class="bg-primary/5 border border-primary/15 rounded-xl px-4 py-3 text-primary text-sm placeholder:text-primary/30 focus:outline-none focus:border-primary/40 focus:ring-2 focus:ring-primary/10 transition-all"
              />
            </div>
          </div>

          <div class="flex flex-col gap-1.5">
            <label for="whatsapp" class="text-primary/70 text-xs font-semibold uppercase tracking-wide">
              WhatsApp
            </label>
            <input
              type="tel"
              id="whatsapp"
              name="whatsapp"
              required
              placeholder="+1 000 000 0000"
              class="bg-primary/5 border border-primary/15 rounded-xl px-4 py-3 text-primary text-sm placeholder:text-primary/30 focus:outline-none focus:border-primary/40 focus:ring-2 focus:ring-primary/10 transition-all"
            />
          </div>

          <div class="flex flex-col gap-1.5">
            <label for="correo" class="text-primary/70 text-xs font-semibold uppercase tracking-wide">
              Correo electrónico
            </label>
            <input
              type="email"
              id="correo"
              name="correo"
              required
              placeholder="tu@email.com"
              class="bg-primary/5 border border-primary/15 rounded-xl px-4 py-3 text-primary text-sm placeholder:text-primary/30 focus:outline-none focus:border-primary/40 focus:ring-2 focus:ring-primary/10 transition-all"
            />
          </div>

          <div class="flex flex-col gap-1.5">
            <label for="sedes" class="text-primary/70 text-xs font-semibold uppercase tracking-wide">
              ¿Cuántas sedes tienes?
            </label>
            <select
              id="sedes"
              name="sedes"
              required
              class="bg-primary/5 border border-primary/15 rounded-xl px-4 py-3 text-primary text-sm focus:outline-none focus:border-primary/40 focus:ring-2 focus:ring-primary/10 transition-all appearance-none cursor-pointer"
            >
              <option value="" disabled selected class="text-primary/30">Selecciona una opción</option>
              <option value="1">1 sede</option>
              <option value="2-3">2 a 3 sedes</option>
              <option value="4-10">4 a 10 sedes</option>
              <option value="10+">Más de 10 sedes</option>
            </select>
          </div>

          <button
            type="submit"
            class="mt-2 w-full bg-primary text-tertiary font-bold py-4 rounded-full hover:bg-primary/90 hover:scale-[1.02] transition-all duration-200 shadow-lg text-base"
          >
            Quiero mi demo gratuita →
          </button>

          <p class="text-primary/40 text-xs text-center">
            Sin spam. Sin tarjeta. Te contactamos en menos de 24h. Garantía 30 días.
          </p>
        </form>
      </div>
    </div>
  </div>
</section>

<!-- FAQ — optimizado para People Also Ask y rich results -->
<section id="faq" class="py-20 bg-primary border-t border-secondary/5" aria-labelledby="faq-heading">
  <div class="max-w-3xl mx-auto px-6">
    <div class="text-center mb-12" data-animate>
      <span class="text-tertiary text-sm font-semibold tracking-widest uppercase">Preguntas frecuentes</span>
      <h2 id="faq-heading" class="text-3xl sm:text-4xl font-black text-secondary mt-3 mb-4">
        Todo lo que necesitas saber sobre klimze.
      </h2>
    </div>

    <div class="flex flex-col gap-4" data-animate data-animate-delay="100">

      <details class="group bg-[#0d0d0d] border border-secondary/10 rounded-2xl overflow-hidden hover:border-tertiary/20 transition-all duration-200">
        <summary class="flex items-center justify-between gap-4 px-6 py-5 cursor-pointer text-secondary font-semibold text-sm list-none">
          ¿Cómo automatiza klimze. las citas de mi clínica?
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4 text-tertiary flex-shrink-0 transition-transform duration-200 group-open:rotate-180" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5" />
          </svg>
        </summary>
        <p class="px-6 pb-5 text-secondary/50 text-sm leading-relaxed">
          klimze. instala un chatbot inteligente en el número de WhatsApp de tu clínica. Cuando un paciente escribe, el bot responde en segundos, consulta la disponibilidad de tus doctores en tiempo real y confirma la cita — sin intervención humana, las 24 horas del día, los 7 días de la semana.
        </p>
      </details>

      <details class="group bg-[#0d0d0d] border border-secondary/10 rounded-2xl overflow-hidden hover:border-tertiary/20 transition-all duration-200">
        <summary class="flex items-center justify-between gap-4 px-6 py-5 cursor-pointer text-secondary font-semibold text-sm list-none">
          ¿Cuánto cuesta el sistema de gestión de citas para clínicas?
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4 text-tertiary flex-shrink-0 transition-transform duration-200 group-open:rotate-180" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5" />
          </svg>
        </summary>
        <p class="px-6 pb-5 text-secondary/50 text-sm leading-relaxed">
          klimze. tiene dos planes principales: Plan Básico desde $89/mes (hasta 200 citas/mes, 1 sede) y Plan Pro desde $149/mes (citas ilimitadas, hasta 2 sedes, reactivación de pacientes, generación de reseñas y más). Existe también un plan Enterprise para redes de clínicas con precio personalizado. Todos los planes incluyen 30 días de prueba gratuita sin tarjeta de crédito.
        </p>
      </details>

      <details class="group bg-[#0d0d0d] border border-secondary/10 rounded-2xl overflow-hidden hover:border-tertiary/20 transition-all duration-200">
        <summary class="flex items-center justify-between gap-4 px-6 py-5 cursor-pointer text-secondary font-semibold text-sm list-none">
          ¿klimze. funciona en Panamá y otros países de Latinoamérica?
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4 text-tertiary flex-shrink-0 transition-transform duration-200 group-open:rotate-180" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5" />
          </svg>
        </summary>
        <p class="px-6 pb-5 text-secondary/50 text-sm leading-relaxed">
          Sí. klimze. está diseñado para clínicas en Panamá, México, Colombia, Costa Rica y toda Latinoamérica. El sistema funciona con cualquier número de WhatsApp Business de la región y está completamente en español.
        </p>
      </details>

      <details class="group bg-[#0d0d0d] border border-secondary/10 rounded-2xl overflow-hidden hover:border-tertiary/20 transition-all duration-200">
        <summary class="flex items-center justify-between gap-4 px-6 py-5 cursor-pointer text-secondary font-semibold text-sm list-none">
          ¿Cuánto tiempo tarda la configuración inicial?
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4 text-tertiary flex-shrink-0 transition-transform duration-200 group-open:rotate-180" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5" />
          </svg>
        </summary>
        <p class="px-6 pb-5 text-secondary/50 text-sm leading-relaxed">
          La configuración completa tarda menos de 24 horas. El equipo de klimze. realiza el onboarding guiado: conecta tu número de WhatsApp, carga tus servicios, horarios, doctores y preferencias — y deja el sistema funcionando desde el primer día.
        </p>
      </details>

      <details class="group bg-[#0d0d0d] border border-secondary/10 rounded-2xl overflow-hidden hover:border-tertiary/20 transition-all duration-200">
        <summary class="flex items-center justify-between gap-4 px-6 py-5 cursor-pointer text-secondary font-semibold text-sm list-none">
          ¿Qué pasa cuando el chatbot no puede responder una consulta?
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4 text-tertiary flex-shrink-0 transition-transform duration-200 group-open:rotate-180" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5" />
          </svg>
        </summary>
        <p class="px-6 pb-5 text-secondary/50 text-sm leading-relaxed">
          Cuando el bot detecta una consulta que supera su alcance, envía una alerta inmediata al dashboard de la clínica para que un humano tome la conversación. Después puedes devolverla al bot en cualquier momento con un solo clic, manteniendo el contexto completo de la conversación.
        </p>
      </details>

      <details class="group bg-[#0d0d0d] border border-secondary/10 rounded-2xl overflow-hidden hover:border-tertiary/20 transition-all duration-200">
        <summary class="flex items-center justify-between gap-4 px-6 py-5 cursor-pointer text-secondary font-semibold text-sm list-none">
          ¿Necesito cambiar mi número de WhatsApp?
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4 text-tertiary flex-shrink-0 transition-transform duration-200 group-open:rotate-180" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5" />
          </svg>
        </summary>
        <p class="px-6 pb-5 text-secondary/50 text-sm leading-relaxed">
          No. klimze. se integra directamente con el número de WhatsApp Business que ya tiene tu clínica. No necesitas cambiar de número ni migrar nada — tus pacientes siguen escribiendo al mismo número de siempre.
        </p>
      </details>

    </div>
  </div>
</section>

<script>
  document.getElementById('demo-form')?.addEventListener('submit', function (e) {
    e.preventDefault();
    const nombre = (document.getElementById('nombre') as HTMLInputElement).value;
    const clinica = (document.getElementById('clinica') as HTMLInputElement).value;
    const whatsapp = (document.getElementById('whatsapp') as HTMLInputElement).value;
    const correo = (document.getElementById('correo') as HTMLInputElement).value;
    const sedes = (document.getElementById('sedes') as HTMLSelectElement).value;

    const mensaje =
      `Hola Karlos, quiero una demo de klimze. 🙌\n\n` +
      `👤 Nombre: ${nombre}\n` +
      `🏥 Clínica: ${clinica}\n` +
      `📱 WhatsApp: ${whatsapp}\n` +
      `📧 Correo: ${correo}\n` +
      `🏢 Sedes: ${sedes}`;

    window.open(`https://wa.me/50765419867?text=${encodeURIComponent(mensaje)}`, '_blank');
  });
</script>
