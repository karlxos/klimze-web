---
const plans = [
  {
    name: 'Básico',
    regularPrice: '$149/mes',
    founderPrice: '$89',
    period: '/mes',
    annualNote: 'o $890/año — ahorras 2 meses',
    desc: 'Para clínicas de 1 profesional que están dando sus primeros pasos.',
    features: [
      '1 sede',
      'Hasta 200 citas/mes',
      'Chatbot de WhatsApp 24/7',
      'Agendamiento automático',
      'Confirmación y recordatorios',
      'CRM básico de pacientes',
    ],
    missing: [
      'Reactivación de pacientes inactivos',
      'Generación automática de reseñas',
      'Pagos anticipados para asegurar citas',
    ],
    cta: 'Empezar con Básico',
    featured: false,
  },
  {
    name: 'Pro',
    regularPrice: '$299/mes',
    founderPrice: '$149',
    period: '/mes',
    annualNote: 'o $1,490/año — ahorras 2 meses',
    desc: 'Todo lo que necesita una clínica para recuperar ingresos perdidos y crecer sola.',
    roi: 'Con solo 5 citas recuperadas al mes, klimze. Pro ya se pagó solo.',
    features: [
      '3 sedes',
      'Citas ilimitadas',
      'Todo lo del plan Básico',
      'Reactivación de pacientes inactivos',
      'Seguimiento post-servicio',
      'Generación automática de reseñas',
      'Sistema de pagos anticipados',
      'Dashboard de rendimiento',
    ],
    missing: [],
    cta: 'Empezar con Pro',
    featured: true,
  },
  {
    name: 'Enterprise',
    regularPrice: null,
    founderPrice: 'A medida',
    period: '',
    annualNote: 'Cotización personalizada',
    desc: 'Para grupos de clínicas, franquicias o redes con múltiples sedes y necesidades a medida.',
    features: [
      'Sedes ilimitadas',
      'Citas ilimitadas',
      'Todo lo del plan Pro',
      'Dashboard avanzado multi-sede',
      'Integraciones personalizadas',
      'Soporte prioritario dedicado',
      'Onboarding guiado',
    ],
    missing: [],
    cta: 'Hablar con ventas',
    featured: false,
  },
];
---

<section id="precios" class="py-24 bg-primary relative overflow-hidden">
  <!-- Glow top -->
  <div
    class="absolute top-0 left-1/2 -translate-x-1/2 w-[800px] h-px pointer-events-none"
    style="background: linear-gradient(90deg, transparent, rgba(147,225,216,0.3), transparent);"
  ></div>

  <div class="max-w-7xl mx-auto px-6">
    <!-- Header -->
    <div class="text-center mb-6">
      <span class="text-tertiary text-sm font-semibold tracking-widest uppercase">Precios</span>
      <h2 class="text-3xl sm:text-4xl md:text-5xl font-black text-secondary mt-3 mb-4">
        Un plan para cada etapa
      </h2>
      <p class="text-secondary/50 text-lg max-w-xl mx-auto">
        Sin costos ocultos. Sin contratos. Empieza en minutos.
      </p>
    </div>

    <!-- Social proof stat -->
    <div class="flex justify-center mb-5">
      <div class="inline-flex items-center gap-2 text-secondary/40 text-sm">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4 text-tertiary/60">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 0 0 2.625.372 9.337 9.337 0 0 0 4.121-.952 4.125 4.125 0 0 0-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 0 1 8.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0 1 11.964-3.07M12 6.375a3.375 3.375 0 1 1-6.75 0 3.375 3.375 0 0 1 6.75 0Zm8.25 2.25a2.625 2.625 0 1 1-5.25 0 2.625 2.625 0 0 1 5.25 0Z" />
        </svg>
        <span>9 de cada 10 clínicas activas en klimze. eligen el plan <span class="text-secondary font-semibold">Pro</span></span>
      </div>
    </div>

    <!-- Founder pricing banner -->
    <div class="flex justify-center mb-12">
      <div class="inline-flex items-center gap-3 bg-tertiary/10 border border-tertiary/30 rounded-full px-5 py-2.5">
        <span class="w-2 h-2 rounded-full bg-tertiary animate-pulse flex-shrink-0"></span>
        <span class="text-tertiary text-sm font-semibold">
          Precio Fundador activo — 50% off de por vida para los primeros 30 clientes
        </span>
        <span class="bg-tertiary/20 text-tertiary text-xs font-black px-2.5 py-1 rounded-full">
          Solo 27 cupos
        </span>
      </div>
    </div>

    <!-- Pricing cards -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 items-start">
      {plans.map((plan) => (
        <div
          class={`relative rounded-3xl p-8 flex flex-col gap-6 border transition-all duration-300 hover:-translate-y-1 ${
            plan.featured
              ? 'bg-secondary border-tertiary shadow-2xl shadow-tertiary/10 scale-[1.02]'
              : 'bg-[#0d0d0d] border-secondary/10 hover:border-tertiary/30'
          }`}
          style={plan.featured ? 'box-shadow: 0 0 60px -10px rgba(147,225,216,0.2), 0 25px 50px -12px rgba(0,0,0,0.5);' : ''}
        >
          {/* Featured badge */}
          {plan.featured && (
            <div class="absolute -top-4 left-1/2 -translate-x-1/2 flex items-center gap-2">
              <span class="bg-tertiary text-primary text-xs font-bold px-4 py-1.5 rounded-full shadow-lg whitespace-nowrap">
                ✦ La que realmente genera ingresos
              </span>
            </div>
          )}

          {/* Plan header */}
          <div>
            <div class="flex items-center justify-between mb-1">
              <h3 class={`text-lg font-bold ${plan.featured ? 'text-primary' : 'text-secondary'}`}>
                {plan.name}
              </h3>
              {plan.regularPrice && (
                <span class={`text-xs font-medium line-through ${plan.featured ? 'text-primary/40' : 'text-secondary/30'}`}>
                  {plan.regularPrice}
                </span>
              )}
            </div>

            <div class="flex items-end gap-1 mb-1">
              <div class={`text-4xl font-black ${plan.featured ? 'text-primary' : 'text-tertiary'}`}>
                {plan.founderPrice}
              </div>
              {plan.period && (
                <div class={`text-base font-medium mb-1 ${plan.featured ? 'text-primary/60' : 'text-secondary/40'}`}>
                  {plan.period}
                </div>
              )}
            </div>

            <p class={`text-xs font-medium mb-3 ${plan.featured ? 'text-primary/50' : 'text-tertiary/60'}`}>
              {plan.annualNote}
            </p>

            <p class={`text-sm leading-relaxed ${plan.featured ? 'text-primary/60' : 'text-secondary/40'}`}>
              {plan.desc}
            </p>
          </div>

          {/* ROI callout — solo en Pro */}
          {plan.roi && (
            <div class="bg-primary/10 border border-primary/20 rounded-xl px-4 py-3 flex items-start gap-3">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4 text-primary/60 flex-shrink-0 mt-0.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18 9 11.25l4.306 4.306a11.95 11.95 0 0 1 5.814-5.518l2.74-1.22m0 0-5.94-2.281m5.94 2.28-2.28 5.941" />
              </svg>
              <p class="text-primary/70 text-xs leading-relaxed font-medium">{plan.roi}</p>
            </div>
          )}

          {/* Features list */}
          <ul class="flex flex-col gap-3 flex-1">
            {plan.features.map((feature) => (
              <li class="flex items-start gap-3">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke-width="2.5"
                  stroke="currentColor"
                  class={`w-4 h-4 mt-0.5 flex-shrink-0 ${plan.featured ? 'text-primary' : 'text-tertiary'}`}
                >
                  <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                </svg>
                <span class={`text-sm ${plan.featured ? 'text-primary/80' : 'text-secondary/60'}`}>
                  {feature}
                </span>
              </li>
            ))}

            {/* Missing features — solo en Básico */}
            {plan.missing.length > 0 && (
              <>
                <li class="border-t border-secondary/8 pt-3 -mx-0">
                  <span class="text-secondary/25 text-xs font-semibold uppercase tracking-widest">No podrás</span>
                </li>
                {plan.missing.map((feature) => (
                  <li class="flex items-start gap-3 opacity-40">
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      fill="none"
                      viewBox="0 0 24 24"
                      stroke-width="2.5"
                      stroke="currentColor"
                      class="w-4 h-4 mt-0.5 flex-shrink-0 text-secondary/60"
                    >
                      <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
                    </svg>
                    <span class="text-sm text-secondary/50 line-through">{feature}</span>
                  </li>
                ))}
              </>
            )}
          </ul>

          {/* CTA */}
          <a
            href="#contacto"
            class={`block text-center font-bold py-3.5 rounded-full transition-all duration-200 hover:scale-[1.02] ${
              plan.featured
                ? 'bg-primary text-tertiary hover:bg-primary/90'
                : 'bg-tertiary/10 border border-tertiary/30 text-tertiary hover:bg-tertiary hover:text-primary'
            }`}
          >
            {plan.cta}
          </a>
        </div>
      ))}
    </div>

    <!-- Guarantee -->
    <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4 text-center">
      <div class="flex items-center gap-3 bg-tertiary/5 border border-tertiary/15 rounded-2xl px-6 py-4">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 text-tertiary flex-shrink-0">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z" />
        </svg>
        <span class="text-secondary/60 text-sm">
          <span class="text-secondary font-semibold">Garantía 30 días:</span> Si no bajan los pacientes que faltan a sus citas, cancelamos sin preguntas.
        </span>
      </div>
      <div class="flex items-center gap-3 bg-tertiary/5 border border-tertiary/15 rounded-2xl px-6 py-4">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 text-tertiary flex-shrink-0">
          <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 8.25h19.5M2.25 9h19.5m-16.5 5.25h6m-6 2.25h3m-3.75 3h15a2.25 2.25 0 0 0 2.25-2.25V6.75A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25v10.5A2.25 2.25 0 0 0 4.5 19.5Z" />
        </svg>
        <span class="text-secondary/60 text-sm">
          <span class="text-secondary font-semibold">Sin tarjeta:</span> 30 días de prueba gratuita, sin compromisos.
        </span>
      </div>
    </div>
  </div>
</section>
