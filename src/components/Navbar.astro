---
---

<header class="fixed top-0 left-0 right-0 z-50 flex justify-center pt-5 px-6 pointer-events-none">

  <!-- Floating pill navbar -->
  <nav
    id="navbar-pill"
    aria-label="Navegación principal de klimze."
    class="pointer-events-auto flex items-center gap-2 px-2 py-2 rounded-full
           bg-primary/80 backdrop-blur-xl border border-secondary/10
           shadow-[0_8px_32px_rgba(0,0,0,0.4)] transition-all duration-300"
  >
    <!-- Logo -->
    <a
      href="/"
      aria-label="klimze. — Automatización de citas para clínicas"
      class="text-lg font-black text-tertiary tracking-tight px-3 py-1 flex-shrink-0"
    >
      klimze.
    </a>

    <!-- Desktop links -->
    <ul class="hidden md:flex items-center text-sm font-medium text-secondary/60">
      <li>
        <a href="#calculadora" class="px-4 py-2 rounded-full hover:text-tertiary hover:bg-tertiary/5 transition-all duration-200 text-tertiary/70">
          Calculadora
        </a>
      </li>
      <li>
        <a href="#funcionalidades" class="px-4 py-2 rounded-full hover:text-secondary hover:bg-secondary/5 transition-all duration-200">
          Funcionalidades
        </a>
      </li>
      <li>
        <a href="#como-funciona" class="px-4 py-2 rounded-full hover:text-secondary hover:bg-secondary/5 transition-all duration-200">
          Cómo funciona
        </a>
      </li>
      <li>
        <a href="#precios" class="px-4 py-2 rounded-full hover:text-secondary hover:bg-secondary/5 transition-all duration-200">
          Precios
        </a>
      </li>
      <li>
        <a href="#faq" class="px-4 py-2 rounded-full hover:text-secondary hover:bg-secondary/5 transition-all duration-200">
          FAQ
        </a>
      </li>
      <li>
        <a href="#contacto" class="px-4 py-2 rounded-full hover:text-secondary hover:bg-secondary/5 transition-all duration-200">
          Contacto
        </a>
      </li>
    </ul>

    <!-- Filled CTA -->
    <a
      href="#contacto"
      aria-label="Solicitar demo gratuita de klimze."
      class="hidden md:inline-flex items-center text-sm font-semibold text-primary
             bg-secondary px-5 py-2 rounded-full
             hover:bg-secondary/90 hover:scale-105 transition-all duration-200 flex-shrink-0"
    >
      Solicitar demo
    </a>

    <!-- Mobile hamburger -->
    <button
      id="mobile-menu-btn"
      class="md:hidden flex flex-col gap-1.5 p-2 mr-1"
      aria-label="Abrir menú"
    >
      <span class="block w-5 h-0.5 bg-secondary transition-all duration-300"></span>
      <span class="block w-5 h-0.5 bg-secondary transition-all duration-300"></span>
      <span class="block w-3 h-0.5 bg-secondary transition-all duration-300"></span>
    </button>
  </nav>

  <!-- Mobile dropdown (below pill) -->
  <div
    id="mobile-menu"
    class="hidden absolute top-full left-6 right-6 mt-2 bg-primary/95 backdrop-blur-xl
           border border-secondary/10 rounded-2xl px-5 py-5 shadow-xl pointer-events-auto"
  >
    <ul class="flex flex-col gap-1 text-sm font-medium text-secondary/70 mb-4">
      <li><a href="#calculadora"     class="block px-3 py-2 rounded-xl hover:bg-tertiary/5 hover:text-tertiary transition-all text-tertiary/60">Calculadora</a></li>
      <li><a href="#funcionalidades" class="block px-3 py-2 rounded-xl hover:bg-secondary/5 hover:text-secondary transition-all">Funcionalidades</a></li>
      <li><a href="#como-funciona"   class="block px-3 py-2 rounded-xl hover:bg-secondary/5 hover:text-secondary transition-all">Cómo funciona</a></li>
      <li><a href="#precios"         class="block px-3 py-2 rounded-xl hover:bg-secondary/5 hover:text-secondary transition-all">Precios</a></li>
      <li><a href="#faq"             class="block px-3 py-2 rounded-xl hover:bg-secondary/5 hover:text-secondary transition-all">FAQ</a></li>
      <li><a href="#contacto"        class="block px-3 py-2 rounded-xl hover:bg-secondary/5 hover:text-secondary transition-all">Contacto</a></li>
    </ul>
    <a
      href="#contacto"
      class="block text-center bg-secondary text-primary font-semibold px-5 py-2.5 rounded-full hover:bg-secondary/90 transition-colors"
    >
      Solicitar demo
    </a>
  </div>

</header>

<script>
  const btn  = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');

  btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));
  menu?.querySelectorAll('a').forEach(link =>
    link.addEventListener('click', () => menu.classList.add('hidden'))
  );
</script>
